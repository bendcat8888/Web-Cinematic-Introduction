 <style>
    @property --sunrise {
      syntax: '<number>';
      initial-value: 0;
      inherits: true;
    }

    @property --section-bg-mix {
      syntax: '<number>';
      initial-value: 1;
      inherits: true;
    }

    @property --capsule-mix {
      syntax: '<number>';
      initial-value: 1;
      inherits: true;
    }

    :root{
      --bg0:#070712;
      --bg1:#0a0a1a;
      --ink:#e9e8ff;
      --muted:#b8b6da;
      --purple:#7a35ff;
      --violet:#b64dff;
      --magenta:#ff3aa8;
      --cyan:#3bf1ff;
      --glass: rgba(16, 14, 34, 0.55);
      --glass2: rgba(10, 9, 24, 0.35);
      --stroke: rgba(190, 175, 255, 0.22);
      --shadow: rgba(0,0,0,0.55);
      --btn: linear-gradient(90deg, rgba(122,53,255,0.95), rgba(182,77,255,0.85), rgba(255,58,168,0.72));
      --btn2: linear-gradient(90deg, rgba(255,58,168,0.62), rgba(122,53,255,0.95));
      --r: 18px;
      --sunrise: 0;
      --vignette: 0;
      --capsules: clamp(0, calc((var(--sunrise) - 0.28) * 1.8), 0.55);
      --section-bg-a: radial-gradient(1200px 900px at 70% 20%, rgba(122,53,255,0.10), transparent 55%),
                      radial-gradient(900px 700px at 25% 65%, rgba(59,241,255,0.07), transparent 60%),
                      linear-gradient(180deg, rgba(10,10,26,0.20), rgba(7,7,18,0.00));
      --section-bg-b: radial-gradient(1200px 900px at 70% 20%, rgba(122,53,255,0.10), transparent 55%),
                      radial-gradient(900px 700px at 25% 65%, rgba(59,241,255,0.07), transparent 60%),
                      linear-gradient(180deg, rgba(10,10,26,0.20), rgba(7,7,18,0.00));
      --section-bg-mix: 1;
      --capsule-a: var(--capsule-bg);
      --capsule-b: var(--capsule-bg);
      --capsule-mix: 1;
      --capsule-size: 520px;
      --capsule-repeat: repeat;
      --capsule-pos-x: 50%;
      --capsule-pos-y: 62%;
      --capsule-mask: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.22) 28%, rgba(0,0,0,1) 64%, rgba(0,0,0,1) 100%);
      --parallax-x: 0px;
      --parallax-y: 0px;
      --particles-opacity: 0;
      --capsule-bg: var(--capsule-bg-future);
      --capsule-bg-classic: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='260'%20height='260'%20viewBox='0%200%20260%20260'%3E%3Cdefs%3E%3ClinearGradient%20id='g1'%20x1='0'%20y1='0'%20x2='1'%20y2='1'%3E%3Cstop%20offset='0'%20stop-color='%233bf1ff'%20stop-opacity='0.45'/%3E%3Cstop%20offset='1'%20stop-color='%237a35ff'%20stop-opacity='0.40'/%3E%3C/linearGradient%3E%3ClinearGradient%20id='g2'%20x1='1'%20y1='0'%20x2='0'%20y2='1'%3E%3Cstop%20offset='0'%20stop-color='%23ff3aa8'%20stop-opacity='0.42'/%3E%3Cstop%20offset='1'%20stop-color='%23ffffff'%20stop-opacity='0.18'/%3E%3C/linearGradient%3E%3C/defs%3E%3Cg%20fill='none'%20stroke='%23ffffff'%20stroke-opacity='0.12'%3E%3Cg%20transform='translate(38%2038)%20rotate(-22%2060%2060)'%3E%3Crect%20x='28'%20y='44'%20width='64'%20height='32'%20rx='16'%20fill='url(%23g1)'%20stroke-opacity='0.18'/%3E%3Cpath%20d='M60%2044v32'%20stroke-opacity='0.22'/%3E%3C/g%3E%3Cg%20transform='translate(128%2068)%20rotate(18%2048%2048)'%3E%3Crect%20x='20'%20y='36'%20width='56'%20height='28'%20rx='14'%20fill='url(%23g2)'%20stroke-opacity='0.18'/%3E%3Cpath%20d='M48%2036v28'%20stroke-opacity='0.22'/%3E%3C/g%3E%3Cg%20transform='translate(76%20150)%20rotate(-8%2052%2052)'%3E%3Crect%20x='26'%20y='42'%20width='62'%20height='30'%20rx='15'%20fill='url(%23g1)'%20stroke-opacity='0.18'/%3E%3Cpath%20d='M57%2042v30'%20stroke-opacity='0.22'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
