  <div class="how-network-layer" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 980 620" role="img" aria-label="Futuristic engagement network">
      <defs>
        <radialGradient id="coreGlowHow" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="#5cb8ff" stop-opacity="0.45"/>
          <stop offset="60%" stop-color="#245dff" stop-opacity="0.12"/>
          <stop offset="100%" stop-color="#245dff" stop-opacity="0"/>
        </radialGradient>

        <filter id="softGlowHow" x="-100%" y="-100%" width="300%" height="300%">
          <feGaussianBlur stdDeviation="6" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>

        <g id="ringNodeHow">
          <circle r="44" fill="rgba(5,12,30,0.88)" stroke="currentColor" stroke-width="3"/>
          <circle r="34" fill="none" stroke="currentColor" stroke-opacity="0.45" stroke-width="1.5"/>
        </g>

        <g id="userIconHow" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="0" cy="-9" r="9"/>
          <path d="M-13 18c0-9 7-16 13-16s13 7 13 16"/>
        </g>

        <g id="shieldIconHow" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M0 -18 L16 -10 V6 c0 12 -10 18 -16 22 c-6 -4 -16 -10 -16 -22 V-10 Z"/>
          <path d="M-8 6 l6 6 l12 -14"/>
        </g>

        <g id="searchIconHow" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
          <circle cx="0" cy="0" r="14"/>
