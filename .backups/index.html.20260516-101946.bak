  <script src="assets/products/products.js"></script>
  <script>
    (() => {
      const canvas = document.getElementById('scene');
      const ctx = canvas.getContext('2d', { alpha: false, desynchronized: true });
      const skipBtn = document.getElementById('skip');
      const maintenancePop = document.getElementById('maintenancePop');
      const maintenanceClose = document.getElementById('maintenanceClose');
      const productsPop = document.getElementById('productsPop');
      const productsClose = document.getElementById('productsClose');
      const productsCategory = document.getElementById('productsCategory');
      const productsSearch = document.getElementById('productsSearch');
      const productsList = document.getElementById('productsList');
      const productsDetail = document.getElementById('productsDetail');
      let lastFocus = null;

      const DPR_LIMIT = 1.6;
      const TAU = Math.PI * 2;
      const IMPACT_END_MS = 3400;
      const IMPACT_REVEAL_MS = 2850;

      const palette = {
        bg0: '#070712',
        bg1: '#0a0a1a',
        ink: 'rgba(233,232,255,0.92)',
        purple: '#7a35ff',
        violet: '#b64dff',
        magenta: '#ff3aa8',
        cyan: '#3bf1ff',
        white: '#ffffff'
      };

      const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
      const lerp = (a, b, t) => a + (b - a) * t;
      const invLerp = (a, b, v) => (v - a) / (b - a);
      const easeOutCubic = t => 1 - Math.pow(1 - t, 3);
      const easeInCubic = t => t * t * t;
      const easeInOut = t => t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      const easeOutExpo = t => t === 1 ? 1 : 1 - Math.pow(2, -10 * t);

      const rand = (a = 0, b = 1) => a + Math.random() * (b - a);
      let resizeRaf = 0;
      function resize() {
        const dprLimit = scene.quality ? scene.quality.dpr : DPR_LIMIT;
        const dpr = Math.min(dprLimit, window.devicePixelRatio || 1);
        const w = Math.floor(innerWidth * dpr);
        const h = Math.floor(innerHeight * dpr);
        if (canvas.width !== w || canvas.height !== h) {
          canvas.width = w;
          canvas.height = h;
        }
        ctx.setTransform(1,0,0,1,0,0);
        ctx.scale(dpr, dpr);
        scene.w = innerWidth;
        scene.h = innerHeight;
        scene.dpr = dpr;
        rebuildPaintCaches();
      }

      const scene = {
        w: innerWidth,
        h: innerHeight,
        dpr: 1,
        t0: performance.now(),
        t: 0,
        dt: 0,
        paint: null,
        paintW: 0,
        paintH: 0,
        cameraShake: 0,
        impactAt: 0,
        revealAt: 0,
        revealed: false,
        skipRequested: false,
        animationStopped: false,
        reduced: false,
        lowPower: false,
        quality: {
          dpr: DPR_LIMIT,
          gridCols: 26,
          gridDepth: 20,
          ringSteps: 96,
          particleScale: 0.85,
          glow: false,
          trailMax: 22
        }
      };

      const ground = {
        horizonY: 0.52,
        gridSpacing: 0.54,
        gridDepth: 30,
        gridCols: 36,
        glow: 1,
        rippleStrength: 0,
        platform: 0,
        surfaceTension: 1
      };

      const capsule = {
        active: true,
        pos: { x: -200, y: -200 },
        vel: { x: 0, y: 0 },
        acc: { x: 0, y: 0 },
        heading: 0,
        rot: 0,
        rotVel: 0,
        size: 54,
        trail: [],
        trailMax: 28
      };

      const impact = {
        x: 0,
        y: 0,
        wx: 0,
        wz: 1.35,
        angle: 0,
        flash: 0,
        elapsed: 0,
        rings: [],
        dust: [],
        sparks: [],
        helix: [],
        started: false
      };

      function worldToScreenOnGround(wx, wz) {
        const horizon = scene.h * ground.horizonY;
        const k = wz / (1 + wz);
        const y = horizon + (scene.h - horizon) * k;
        const x = scene.w * 0.5 + wx * k * (scene.w * 0.30);
        return { x, y };
      }

      function groundWave(wx, wz) {
        if (!impact.started) return 0;
        const since = impact.elapsed / 1000;
        const dx = wx - impact.wx;
        const dz = (wz - impact.wz) * 1.08;
        const dist = Math.sqrt(dx * dx + dz * dz);
        const base = ground.rippleStrength * (1 - ground.platform * 0.42) * ground.surfaceTension;
        if (base <= 0.001) return 0;

        const broadFall = Math.exp(-dist * 0.105) * Math.max(0, 1 - dist / 24);
        const localFall = Math.exp(-dist * 0.24) * Math.max(0, 1 - dist / 16);

        const shockRadius = since * 4.45;
        const shockWidth = 1.02 + since * 0.24;
        const crest = Math.exp(-Math.pow((dist - shockRadius) / shockWidth, 2));
        const trough = Math.exp(-Math.pow((dist - shockRadius + shockWidth * 0.95) / (shockWidth * 1.55), 2));
        const ringWave = crest * 0.95 - trough * 0.34;

        const wake = Math.sin(dist * 1.38 - since * 4.75) * broadFall * Math.max(0, 1 - since * 0.20);
        const capillary = Math.sin(dist * 3.1 - since * 7.2 + 0.7) * Math.exp(-dist * 0.48) * Math.max(0, 1 - since * 0.42);
        const centralWell = -Math.exp(-dist * dist * 0.86) * Math.max(0, 1 - since * 0.82);
        const rebound = Math.exp(-dist * dist * 0.46) * Math.sin(since * 5.2) * Math.max(0, 1 - since * 0.66);

        const ca = Math.cos(impact.angle || 0);
        const sa = Math.sin(impact.angle || 0);
        const rx = dx * ca - dz * sa;
        const rz = dx * sa + dz * ca;
        const press = -Math.exp(-(rx * rx) / (1.0 * 1.0) - (rz * rz) / (1.8 * 1.8)) * Math.max(0, 1 - since * 0.95);

        const viewerCenter = impact.wz + since * 2.55;
        const forwardWake = Math.exp(-Math.pow((wz - viewerCenter) / 1.28, 2)) *
          Math.exp(-Math.pow((wx - impact.wx) / 5.6, 2)) *
          Math.sin((wz - viewerCenter) * 1.95) *
          Math.max(0, 1 - since * 0.25);

        const rawWave = base * (
          ringWave * 0.30 * broadFall +
          wake * 0.075 +
          capillary * 0.018 +
          centralWell * 0.24 * localFall +
          rebound * 0.070 * localFall +
          press * 0.42 +
          forwardWake * 0.080
        );
        return Math.tanh(rawWave * 2.4) / 2.4;
      }

      function groundStress(wx, wz) {
        if (!impact.started) return 0;
        const since = impact.elapsed / 1000;
        const dx = wx - impact.wx;
        const dz = (wz - impact.wz) * 1.08;
        const dist = Math.sqrt(dx * dx + dz * dz);
        const shockRadius = since * 4.45;
        const shockWidth = 1.35 + since * 0.22;
        const crest = Math.exp(-Math.pow((dist - shockRadius) / shockWidth, 2));
        const pressure = Math.exp(-dist * dist * 0.76) * Math.max(0, 1 - since * 0.72);
        const viewerWake = Math.exp(-Math.pow((wz - (impact.wz + since * 2.4)) / 0.75, 2)) *
          Math.exp(-Math.pow((wx - impact.wx) / 5.8, 2)) *
          Math.max(0, 1 - since / 2.7);
        return clamp((crest * 0.72 + pressure * 0.38 + viewerWake * 0.34) * ground.rippleStrength * (1 - ground.platform * 0.36), 0, 1);
      }

      function impactGridVisibility(wx, wz) {
        if (!impact.started) return 1;
        const since = Math.max(0, scene.t - scene.impactAt);
        const collapse = clamp((since - 1480) / 980, 0, 1);
        if (collapse <= 0.001) return 1;

        const dx = wx - impact.wx;
        const dz = (wz - impact.wz) * 1.06;
        const dist = Math.sqrt(dx * dx + dz * dz);
        const radius = lerp(5.6, 1.15, easeOutCubic(collapse));
        const tunnel = Math.exp(-Math.pow(dist / radius, 2));
        const floor = lerp(0.18, 0.0, collapse);
        return clamp(1 - tunnel * collapse * 0.98, floor, 1);
      }

      function worldToScreenWire(wx, wz) {
        const wave = groundWave(wx, wz);
        const p = worldToScreenOnGround(wx, wz);
        const k = wz / (1 + wz);
        p.y -= wave * scene.h * (0.095 + k * 0.082);
        p.wave = wave;
        p.persp = k;
        p.stress = groundStress(wx, wz);
        return p;
      }

      function drawApproachingMicroGrid(revealFade, intensity) {
        if (!impact.started || scene.reduced || revealFade <= 0.001) return;
        const since = impact.elapsed / 1000;
        if (since < 0.35 || since > 2.45) return;

        const rb = ground.rippleStrength;
        const travel = clamp((since - 0.35) / 2.1, 0, 1);
        const wakeZ = impact.wz + lerp(0.25, 7.8, easeOutCubic(travel));
        const bandDepth = lerp(0.72, 1.55, travel);
        const wakeWidth = lerp(3.2, 9.4, travel);
        const alpha = rb * Math.sin(travel * Math.PI) * 0.42 * revealFade * intensity;
        if (alpha <= 0.01) return;

        const rows = scene.lowPower ? 4 : 7;
        const cols = scene.lowPower ? 16 : 26;
        const colStep = wakeWidth / cols;

        ctx.save();
        ctx.globalCompositeOperation = 'lighter';
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.shadowBlur = scene.quality.glow ? 8 : 0;
        ctx.shadowColor = `rgba(59,241,255,${0.16 + rb * 0.12})`;

        for (let r = -rows; r <= rows; r++) {
          const z = Math.max(0.48, wakeZ + r * bandDepth / rows);
          const rowFade = Math.exp(-Math.pow(r / rows, 2) * 1.25);
          ctx.globalAlpha = alpha * rowFade * 0.55;
          ctx.strokeStyle = r === 0 ? 'rgba(233,232,255,0.58)' : 'rgba(140,255,248,0.40)';
          ctx.lineWidth = r === 0 ? 0.78 : 0.48;
          ctx.beginPath();
          for (let c = -cols; c <= cols; c++) {
            const wx = impact.wx + c * colStep;
            const p = worldToScreenWire(wx, z);
            if (c === -cols) ctx.moveTo(p.x, p.y);
            else ctx.lineTo(p.x, p.y);
          }
          ctx.stroke();
        }

        ctx.globalAlpha = alpha * 0.24;
        ctx.strokeStyle = 'rgba(233,232,255,0.42)';
        ctx.lineWidth = 0.42;
        const verticals = scene.lowPower ? 12 : 20;
        for (let c = -verticals; c <= verticals; c++) {
          const wx = impact.wx + c * (wakeWidth / verticals);
          ctx.beginPath();
          for (let r = -rows; r <= rows; r++) {
            const z = Math.max(0.48, wakeZ + r * bandDepth / rows);
            const p = worldToScreenWire(wx, z);
            if (r === -rows) ctx.moveTo(p.x, p.y);
            else ctx.lineTo(p.x, p.y);
          }
          ctx.stroke();
        }

        ctx.restore();
      }

      function impactWaveEllipsePath(cx, cy, rx, ry, radius, phase, strength = 1) {
        const steps = scene.lowPower ? 80 : 132;
        const age = Math.max(0, (scene.t - scene.impactAt) / 1000);
        const decay = clamp(1 - radius / Math.max(scene.w, scene.h) * 1.15, 0.18, 1);
        const amp = Math.min(rx, ry * 3.2) * 0.045 * strength * decay;

        ctx.beginPath();
        for (let i = 0; i <= steps; i++) {
          const a = (i / steps) * TAU;
          const front = 0.68 + 0.32 * Math.max(0, Math.sin(a));
          const rippleA = Math.sin(a * 5.0 - age * 8.4 + phase);
          const rippleB = Math.sin(a * 8.0 + age * 5.2 + phase * 0.7) * 0.34;
          const broad = Math.sin(a * 2.0 - age * 3.0 + phase * 0.35) * 0.28;
          const offset = (rippleA + rippleB + broad) * amp * front;
          const x = cx + Math.cos(a) * (rx + offset);
          const y = cy + Math.sin(a) * (ry + offset * 0.42);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.closePath();
      }

      function drawImpactIntensityRing(radius, alpha, lineWidth, shock = false, collapse = 0) {
        const perspective = 1 / (1 + impact.wz);
        const rx = Math.max(8, radius * (1.06 + perspective * 0.22));
        const ry = Math.max(3, radius * (0.18 + perspective * 0.12));
        const lift = Math.min(scene.h * 0.06, radius * 0.018);
        const cy = impact.y - lift;
        const glow = (shock ? 1.15 : 1) + collapse * 0.32;
        const phase = radius * 0.025 + (shock ? 1.7 : 0) + collapse * 1.2;
        const strength = (shock ? 1.28 : 1) + collapse * 0.45;

        ctx.save();
        ctx.globalCompositeOperation = 'lighter';

        ctx.globalAlpha = alpha * 0.22 * glow;
        ctx.strokeStyle = shock ? 'rgba(255,255,255,0.82)' : 'rgba(59,241,255,0.76)';
        ctx.lineWidth = lineWidth * 4.6;
        impactWaveEllipsePath(impact.x, cy, rx, ry, radius, phase, strength * 0.78);
        ctx.stroke();

        ctx.globalAlpha = alpha * 0.34 * glow;
        ctx.strokeStyle = shock ? 'rgba(233,232,255,0.88)' : 'rgba(140,255,248,0.82)';
        ctx.lineWidth = lineWidth * 2.25;
        impactWaveEllipsePath(impact.x, cy, rx * 0.997, ry * 0.997, radius, phase + 0.22, strength);
        ctx.stroke();

        ctx.globalAlpha = alpha * 0.78;
        ctx.strokeStyle = shock ? 'rgba(255,255,255,0.96)' : 'rgba(59,241,255,0.92)';
        ctx.lineWidth = Math.max(0.6, lineWidth);
        impactWaveEllipsePath(impact.x, cy, rx, ry, radius, phase + 0.42, strength * 1.16);
        ctx.stroke();

        ctx.globalAlpha = alpha * 0.18;
        ctx.strokeStyle = 'rgba(255,255,255,0.86)';
        ctx.lineWidth = Math.max(0.45, lineWidth * 0.42);
        impactWaveEllipsePath(impact.x, cy, rx * 0.92, ry * 0.82, radius * 0.92, phase + 0.85, strength * 0.72);
        ctx.stroke();

        if (collapse > 0.02) {
          ctx.globalAlpha = alpha * collapse * 0.28;
          ctx.strokeStyle = 'rgba(233,232,255,0.64)';
          ctx.lineWidth = Math.max(0.45, lineWidth * 0.36);
          const pulls = scene.lowPower ? 10 : 16;
          for (let i = 0; i < pulls; i++) {
            const a = (i / pulls) * TAU + phase * 0.08;
            const front = 0.45 + 0.55 * Math.max(0, Math.sin(a));
            const x0 = impact.x + Math.cos(a) * rx * (0.62 + collapse * 0.18);
            const y0 = cy + Math.sin(a) * ry * (0.62 + collapse * 0.18);
            const x1 = impact.x + Math.cos(a) * rx * (0.22 + collapse * 0.08);
            const y1 = cy + Math.sin(a) * ry * (0.22 + collapse * 0.08);
            ctx.globalAlpha = alpha * collapse * front * 0.20;
            ctx.beginPath();
            ctx.moveTo(x0, y0);
            ctx.lineTo(x1, y1);
            ctx.stroke();
          }
        }

        ctx.restore();
      }

      function drawImpactCorePulse(revealFade, intensity) {
        if (!impact.started || revealFade <= 0.001) return;
        const since = Math.max(0, scene.t - scene.impactAt);
        const heat = clamp(1 - since / 1450, 0, 1);
        if (heat <= 0.01) return;

        const perspective = 1 / (1 + impact.wz);
        const base = Math.min(scene.w, scene.h) * (0.075 + perspective * 0.035);
        const pulse = 0.82 + Math.sin(since * 0.012) * 0.18;
        const alpha = heat * pulse * revealFade * intensity;

        ctx.save();
        ctx.globalCompositeOperation = 'lighter';
        ctx.globalAlpha = alpha * 0.34;
        ctx.strokeStyle = 'rgba(255,255,255,0.90)';
        ctx.lineWidth = 2.2;
        impactWaveEllipsePath(impact.x, impact.y - base * 0.08, base * 1.55, base * 0.42, base, since * 0.006, 1.05);
        ctx.stroke();

        ctx.globalAlpha = alpha * 0.28;
        ctx.strokeStyle = 'rgba(59,241,255,0.78)';
        ctx.lineWidth = 1.3;
        impactWaveEllipsePath(impact.x, impact.y - base * 0.04, base * 2.15, base * 0.58, base * 1.25, since * 0.005 + 0.7, 0.88);
        ctx.stroke();
        ctx.restore();
      }

      function updateQuality() {
        const reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const coarsePointer = window.matchMedia && window.matchMedia('(pointer: coarse)').matches;
        const narrow = Math.min(innerWidth, innerHeight) < 720;
        const lowCores = navigator.hardwareConcurrency && navigator.hardwareConcurrency <= 4;
        const lowMemory = navigator.deviceMemory && navigator.deviceMemory <= 4;
        const lowPower = reduced || coarsePointer || narrow || lowCores || lowMemory;

        scene.reduced = !!reduced;
        scene.lowPower = !!lowPower;

        const q = reduced
          ? { dpr: 1, gridCols: 12, gridDepth: 10, ringSteps: 48, particleScale: 0.26, glow: false, trailMax: 10 }
          : lowPower
            ? { dpr: 1.15, gridCols: 16, gridDepth: 12, ringSteps: 60, particleScale: 0.34, glow: false, trailMax: 14 }
            : { dpr: DPR_LIMIT, gridCols: 22, gridDepth: 16, ringSteps: 80, particleScale: 0.75, glow: false, trailMax: 20 };

        scene.quality = q;
        ground.gridCols = q.gridCols;
        ground.gridDepth = q.gridDepth;
        capsule.trailMax = q.trailMax;
        if (capsule.trail.length > q.trailMax) {
          capsule.trail.splice(0, capsule.trail.length - q.trailMax);
        }
      }

      function capsuleShadowOnGround(cx, cy) {
        const horizon = scene.h * ground.horizonY;
        const t = clamp(invLerp(horizon - 180, scene.h * 0.96, cy), 0, 1);
        const wz = lerp(9.5, 0.75, easeOutCubic(t));
        const k = wz / (1 + wz);
        const wx = (cx - scene.w * 0.5) / (scene.w * 0.30) / Math.max(0.001, k);
        const p = worldToScreenOnGround(wx, wz);
        return { ...p, wz, wx, t };
      }

      function addParticles() {
        impact.dust.length = 0;
        impact.sparks.length = 0;
        impact.rings.length = 0;
        impact.helix.length = 0;

        const particleScale = scene.quality ? scene.quality.particleScale : 1;
        const dustCount = Math.round((scene.reduced ? 60 : 110) * particleScale);
        const sparkCount = Math.round((scene.reduced ? 34 : 60) * particleScale);
        const helixCount = 0;

        for (let i = 0; i < dustCount; i++) {
          const ang = rand(0, TAU);
          const sp = rand(0.35, 2.2);
          impact.dust.push({
            x: impact.x + Math.cos(ang) * rand(0, 14),
            y: impact.y + Math.sin(ang) * rand(0, 10),
            vx: Math.cos(ang) * sp * rand(0.45, 1.0),
            vy: Math.sin(ang) * sp * rand(0.35, 0.9),
            r: rand(0.8, 2.6),
            a: rand(0.18, 0.55),
            life: rand(1200, 2200)
          });
        }

        for (let i = 0; i < sparkCount; i++) {
          const ang = rand(-Math.PI * 0.12, Math.PI * 1.12);
          const sp = rand(1.5, 6.2);
          impact.sparks.push({
            x: impact.x,
            y: impact.y,
            vx: Math.cos(ang) * sp,
            vy: Math.sin(ang) * sp * 0.75,
            r: rand(0.9, 2.2),
            a: rand(0.28, 0.9),
            life: rand(300, 820),
            hue: Math.random() < 0.18 ? 'cyan' : (Math.random() < 0.55 ? 'violet' : 'purple')
          });
        }

        for (let i = 0; i < 4; i++) {
          const maxR = Math.min(scene.w, scene.h) * rand(0.72, 0.96) * (1 + i * 0.055);
          impact.rings.push({
            r: 0,
            v: rand(1.05, 1.9) * (1 + i * 0.16),
            a: 0.95,
            w: rand(1.0, 2.0),
            maxR,
            age: 0,
            hold: 120 + i * 65,
            collapse: 0,
            state: 'expand'
          });
        }

        impact.rings.push({
          r: 0,
          v: rand(6.0, 7.8),
          a: 0.62,
          w: 0.9,
          maxR: Math.min(scene.w, scene.h) * 1.14,
          age: 0,
          hold: 80,
          collapse: 0,
          state: 'expand',
          shock: true
        });

        for (let i = 0; i < helixCount; i++) {
          impact.helix.push({
            phase: rand(0, TAU),
            dir: rand(-1, 1),
            a: rand(0.10, 0.24),
            life: rand(900, 1600),
            speed: rand(0.55, 1.0)
          });
        }
      }

      function rebuildPaintCaches() {
        const w = scene.w, h = scene.h;
        if (scene.paint && scene.paintW === w && scene.paintH === h) return;

        const rg = ctx.createRadialGradient(w * 0.68, h * 0.22, 0, w * 0.68, h * 0.22, Math.max(w, h) * 0.85);
        rg.addColorStop(0, 'rgba(122,53,255,0.13)');
        rg.addColorStop(0.52, 'rgba(122,53,255,0.03)');
        rg.addColorStop(1, 'rgba(0,0,0,0)');

        const cg = ctx.createRadialGradient(w * 0.22, h * 0.70, 0, w * 0.22, h * 0.70, Math.max(w, h) * 0.75);
        cg.addColorStop(0, 'rgba(59,241,255,0.08)');
        cg.addColorStop(0.55, 'rgba(59,241,255,0.02)');
        cg.addColorStop(1, 'rgba(0,0,0,0)');

        const horizon = h * ground.horizonY;
        const haze = ctx.createLinearGradient(0, horizon - 140, 0, h);
        haze.addColorStop(0, 'rgba(5,5,14,0)');
        haze.addColorStop(0.35, 'rgba(8,8,22,0.65)');
        haze.addColorStop(1, 'rgba(5,5,14,0.98)');

        const floorGlow = ctx.createRadialGradient(w * 0.5, h * 0.98, 0, w * 0.5, h * 0.98, Math.max(w, h) * 0.72);
        floorGlow.addColorStop(0, 'rgba(122,53,255,0.14)');
        floorGlow.addColorStop(0.35, 'rgba(182,77,255,0.06)');
        floorGlow.addColorStop(1, 'rgba(0,0,0,0)');

        scene.paint = { rg, cg, haze, floorGlow };
        scene.paintW = w;
        scene.paintH = h;
      }

      function drawBackground() {
        const w = scene.w, h = scene.h;

        rebuildPaintCaches();

        ctx.fillStyle = palette.bg0;
        ctx.fillRect(0, 0, w, h);

        ctx.fillStyle = scene.paint.rg;
        ctx.fillRect(0, 0, w, h);

        ctx.fillStyle = scene.paint.cg;
        ctx.fillRect(0, 0, w, h);

        const horizon = h * ground.horizonY;
        ctx.fillStyle = scene.paint.haze;
        ctx.fillRect(0, horizon - 180, w, h - (horizon - 180));
      }

      function drawGround() {
        const w = scene.w, h = scene.h;
        const horizon = h * ground.horizonY;
        const platform = ground.platform;
        const revealFade = scene.revealed ? clamp(1 - (scene.t - scene.revealAt) / 650, 0, 1) : 1;
        const sinceImpact = impact.started ? Math.max(0, scene.t - scene.impactAt) : 0;
        const irisCollapse = (impact.started && platform > 0.001) ? clamp((sinceImpact - 1580) / 720, 0, 1) : 0;
        const irisEase = easeOutCubic(irisCollapse);
        const irisFade = impact.started ? Math.pow(1 - irisEase, 1.55) : 1;

        ctx.save();
        ctx.beginPath();
        ctx.rect(0, horizon - 6, w, h - horizon + 6);
        ctx.clip();

        const intensity = lerp(0.9, 0.45, platform);
        const rippleBoost = ground.rippleStrength;

        ctx.globalCompositeOperation = 'lighter';
        ctx.globalAlpha = 0.95 * intensity * revealFade;

        const cols = ground.gridCols;
        const rows = ground.gridDepth;
        const colStep = ground.gridSpacing;
        const zNear = 0.62;
        const zStep = colStep * 0.92;
        const centerX = w * 0.5;
        const scaleX = w * 0.32;
        const groundSpan = h - horizon;

        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        const gridTestVisible = !scene.revealed;
        const showGrid = irisFade > 0.01 && revealFade > 0.001 && (gridTestVisible || (impact.started && rippleBoost > 0.02));
        const rb = impact.started ? rippleBoost : 0;
        let gridFactor = gridTestVisible ? 0.92 : 1;
        if (scene.lowPower) gridFactor *= 1.18;
        if (scene.dt > 28) gridFactor *= 1.12;
        const colsDraw = Math.max(10, Math.round(cols / gridFactor));
        const rowsDraw = Math.max(10, Math.round(rows / gridFactor));
        const colStepDraw = colStep * gridFactor;
        const zStepDraw = zStep * gridFactor;

        if (showGrid) {
          ctx.shadowBlur = gridTestVisible ? 0 : (scene.quality.glow ? 10 + rb * 16 : 0);
          ctx.shadowColor = `rgba(59,241,255,${0.16 + rb * 0.16})`;

          for (let r = 0; r <= rowsDraw; r++) {
            const z = zNear + r * zStepDraw;
            const fade = 1 - r / (rowsDraw + 2);
            const baseAlpha = (gridTestVisible ? (0.18 + rb * 0.12) : (0.10 + rb * 0.18)) * intensity * fade * revealFade * irisFade;
            let rowStress = 0;
            let rowVisibility = 0;
            let rowSamples = 0;
            for (let c = -colsDraw; c <= colsDraw; c += Math.max(1, Math.round(colsDraw / 7))) {
              const wxSample = c * colStepDraw;
              rowStress = Math.max(rowStress, groundStress(wxSample, z));
              rowVisibility += impactGridVisibility(wxSample, z);
              rowSamples++;
            }
            rowVisibility = rowSamples ? rowVisibility / rowSamples : 1;
            ctx.globalAlpha = Math.min(1, baseAlpha + rowStress * 0.14) * rowVisibility;
            ctx.strokeStyle = rowStress > 0.20
              ? `rgba(233,232,255,${0.44 + rowStress * 0.34})`
              : (r % 4 === 0 ? 'rgba(233,232,255,0.52)' : 'rgba(140,255,248,0.30)');
            ctx.lineWidth = (r % 4 === 0 ? 1.0 : 0.65) + rowStress * 0.42;
            ctx.beginPath();
            for (let c = -colsDraw; c <= colsDraw; c++) {
              const wx = c * colStepDraw;
              const p = worldToScreenWire(wx, z);
              if (c === -colsDraw) ctx.moveTo(p.x, p.y);
              else ctx.lineTo(p.x, p.y);
            }
            ctx.stroke();
          }

          for (let worldCol = -colsDraw; worldCol <= colsDraw; worldCol++) {
            const wx = worldCol * colStepDraw;
            const centerWeight = 1 - Math.min(1, Math.abs(worldCol) / colsDraw);
            const baseAlpha = (gridTestVisible ? (0.12 + centerWeight * 0.12 + rb * 0.10) : (0.08 + centerWeight * 0.10 + rb * 0.14)) * intensity * revealFade * irisFade;
            let colStress = 0;
            let colVisibility = 0;
            let colSamples = 0;
            for (let r = 0; r <= rowsDraw; r += Math.max(1, Math.round(rowsDraw / 7))) {
              const zSample = zNear + r * zStepDraw;
              colStress = Math.max(colStress, groundStress(wx, zSample));
              colVisibility += impactGridVisibility(wx, zSample);
              colSamples++;
            }
            colVisibility = colSamples ? colVisibility / colSamples : 1;
            ctx.globalAlpha = Math.min(1, baseAlpha + colStress * 0.13) * colVisibility;
            ctx.strokeStyle = colStress > 0.18
              ? `rgba(140,255,248,${0.42 + colStress * 0.32})`
              : (worldCol === 0 ? 'rgba(233,232,255,0.46)' : (worldCol % 4 === 0 ? 'rgba(233,232,255,0.42)' : 'rgba(140,255,248,0.28)'));
            ctx.lineWidth = (worldCol % 4 === 0 ? 0.95 : 0.60) + colStress * 0.36;
            ctx.beginPath();
            for (let r = 0; r <= rowsDraw; r++) {
              const z = zNear + r * zStepDraw;
              const p = worldToScreenWire(wx, z);
              if (r === 0) ctx.moveTo(p.x, p.y);
              else ctx.lineTo(p.x, p.y);
            }
            ctx.stroke();
          }
        }

        if (impact.started && revealFade > 0.001) {
          const since = Math.max(0, scene.t - scene.impactAt);
          const collapse = clamp((since - 1480) / 980, 0, 1);
          if (collapse > 0.001) {
            const radius = Math.min(w, h) * lerp(0.30, 0.08, easeOutCubic(collapse));
            const mask = ctx.createRadialGradient(impact.x, impact.y + 4, 0, impact.x, impact.y + 4, radius * 2.15);
            mask.addColorStop(0, `rgba(7,7,18,${0.38 * collapse * revealFade})`);
            mask.addColorStop(0.42, `rgba(7,7,18,${0.20 * collapse * revealFade})`);
            mask.addColorStop(1, 'rgba(7,7,18,0)');
            ctx.save();
            ctx.globalCompositeOperation = 'source-over';
            ctx.fillStyle = mask;
            ctx.beginPath();
            ctx.ellipse(impact.x, impact.y + 4, radius * 2.15, radius * 0.78, 0, 0, TAU);
            ctx.fill();
            ctx.restore();
            ctx.globalCompositeOperation = 'lighter';
          }
        }

        drawApproachingMicroGrid(revealFade, intensity);
        drawImpactCorePulse(revealFade, intensity);

        if (impact.started && revealFade > 0.001) {
          ctx.shadowBlur = scene.quality.glow ? 24 : 0;
          ctx.shadowColor = 'rgba(59,241,255,0.42)';
          for (const ring of impact.rings) {
            if (ring.a <= 0.02) continue;
            const ringAlphaBase = ring.a * (0.72 + rippleBoost * 0.88) * (1 - platform * 0.45) * revealFade;
            const ringAlpha = ring.shock ? ringAlphaBase * 0.82 : ringAlphaBase;
            const screenRadius = ring.r * (ring.shock ? 0.58 : 0.50);
            const collapse = ring.collapse || 0;
            const alpha = (ring.shock ? ringAlpha * 0.74 : ringAlpha * 0.82) * (1 + collapse * 0.26);
            const lineWidth = ring.shock ? Math.max(0.85, ring.w * 0.95) : Math.max(0.9, ring.w * 1.35);
            drawImpactIntensityRing(screenRadius, alpha, lineWidth * (1 - collapse * 0.24), !!ring.shock, collapse);
          }
        }

        ctx.shadowBlur = 0;

        ctx.globalCompositeOperation = 'source-over';

        ctx.save();
        ctx.globalAlpha = intensity * Math.max(0.06, irisFade);
        ctx.fillStyle = scene.paint.floorGlow;
        ctx.fillRect(0, horizon - 20, w, h - horizon + 20);
        ctx.restore();

        if (impact.started && revealFade > 0.001) {
          const since = Math.max(0, scene.t - scene.impactAt);
          const heat = clamp(1 - since / 2200, 0, 1);
          if (heat > 0.01 && platform > 0.01) {
            const pulse = 0.7 + 0.3 * Math.sin(since * 0.006);
            const base = Math.min(w, h) * 0.08;
            const r0 = base * (1.2 + heat * 2.6);
            const rg = ctx.createRadialGradient(impact.x, impact.y + 8, 0, impact.x, impact.y + 8, r0 * 3.2);
            rg.addColorStop(0, 'rgba(255,255,255,0.35)');
            rg.addColorStop(0.16, 'rgba(255,210,140,0.30)');
            rg.addColorStop(0.36, 'rgba(59,241,255,0.18)');
            rg.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.save();
            ctx.globalCompositeOperation = 'lighter';
            ctx.globalAlpha = heat * pulse * 0.75 * (1 - platform * 0.35) * revealFade;
            ctx.fillStyle = rg;
            ctx.beginPath();
            ctx.ellipse(impact.x, impact.y + 10, r0 * 2.15, r0 * 0.9, 0, 0, TAU);
            ctx.fill();
            ctx.restore();
          }
        }

        if (platform > 0.001 && revealFade > 0.001) {
          const since = Math.max(0, scene.t - scene.impactAt);
          const expand = clamp((since - 1180) / 620, 0, 1);
          const collapse = clamp((since - 1580) / 720, 0, 1);
          const expandEase = easeOutCubic(expand);
          const collapseEase = easeOutCubic(collapse);
          const tunnelScale = lerp(expandEase, 0.07, collapseEase);
          const tunnelAlpha = (0.55 + collapse * 0.20) * Math.pow(1 - collapse, 1.45);
          const r0 = Math.min(w, h) * 0.23 * tunnelScale;
          const cy = impact.y + 6 - Math.min(scene.h * 0.045, r0 * 0.12 * collapse);

          ctx.globalCompositeOperation = 'lighter';
          ctx.globalAlpha = tunnelAlpha * revealFade;
          ctx.strokeStyle = 'rgba(233,232,255,0.20)';
          ctx.lineWidth = 1.1 + collapse * 0.55;
          impactWaveEllipsePath(impact.x, cy, r0 * 1.75, r0 * 0.72, r0, since * 0.004, 0.62 + collapse * 0.78);
          ctx.stroke();

          ctx.globalAlpha = tunnelAlpha * 0.78 * revealFade;
          ctx.strokeStyle = 'rgba(122,53,255,0.40)';
          ctx.lineWidth = 1.0;
          for (let i = 1; i <= 4; i++) {
            const rr = r0 * (0.62 + i * 0.30);
            const layerCollapse = clamp(collapse + i * 0.045, 0, 1);
            const layerAlpha = tunnelAlpha * (1 - i * 0.13) * (0.72 + layerCollapse * 0.30) * revealFade;
            ctx.globalAlpha = layerAlpha;
            ctx.strokeStyle = i % 2 ? 'rgba(122,53,255,0.38)' : 'rgba(59,241,255,0.26)';
            impactWaveEllipsePath(impact.x, cy, rr * 1.65, rr * 0.65, rr, since * 0.004 + i * 0.45, 0.58 + layerCollapse * 0.95);
            ctx.stroke();
          }

          ctx.globalAlpha = tunnelAlpha * 0.42 * revealFade;
          ctx.strokeStyle = 'rgba(59,241,255,0.35)';
          ctx.lineWidth = 0.95;
          impactWaveEllipsePath(impact.x, cy, r0 * 2.3, r0 * 0.9, r0 * 1.2, since * 0.004 + 1.1, 0.52 + collapse * 0.65);
          ctx.stroke();

          if (collapse > 0.04 && r0 > 3) {
            const pulls = scene.lowPower ? 10 : 18;
            ctx.lineWidth = 0.58;
            ctx.strokeStyle = 'rgba(233,232,255,0.54)';
            for (let i = 0; i < pulls; i++) {
              const a = (i / pulls) * TAU + since * 0.0017;
              const front = 0.45 + 0.55 * Math.max(0, Math.sin(a));
              const x0 = impact.x + Math.cos(a) * r0 * 1.45;
              const y0 = cy + Math.sin(a) * r0 * 0.52;
              const x1 = impact.x + Math.cos(a) * r0 * 0.25;
              const y1 = cy + Math.sin(a) * r0 * 0.10;
              ctx.globalAlpha = collapse * tunnelAlpha * front * 0.34 * revealFade;
              ctx.beginPath();
              ctx.moveTo(x0, y0);
              ctx.lineTo(x1, y1);
              ctx.stroke();
            }
          }

          ctx.globalAlpha = 1;
          ctx.globalCompositeOperation = 'source-over';
        }

        ctx.restore();
      }

      function drawCapsule() {
        if (!capsule.active) return;

        const w = scene.w, h = scene.h;
        const s = capsule.size;
        const x = capsule.pos.x;
        const y = capsule.pos.y;
        const rot = capsule.rot;

        ctx.save();

        ctx.globalCompositeOperation = 'lighter';
        ctx.globalAlpha = 0.6;
        for (let i = 0; i < capsule.trail.length; i++) {
          const p = capsule.trail[i];
          const t = i / capsule.trail.length;
          const u = 1 - t;
          const a = 0.035 + u * 0.15;
          const c = u > 0.7
            ? `rgba(255,255,255,${a})`
            : (u > 0.35 ? `rgba(59,241,255,${a})` : `rgba(255,58,168,${a})`);
          ctx.strokeStyle = c;
          ctx.lineWidth = lerp(10, 2, t);
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          const p2 = capsule.trail[Math.min(i + 1, capsule.trail.length - 1)];
          ctx.lineTo(p2.x, p2.y);
          ctx.stroke();
        }

        if (!scene.reduced && capsule.trail.length > 3) {
          const budget = scene.lowPower ? 10 : 22;
          const step = scene.lowPower ? 4 : 3;
          const jitter = s * 0.36;
          let drawn = 0;
          ctx.save();
          ctx.globalCompositeOperation = 'lighter';
          ctx.globalAlpha = 0.16;
          ctx.fillStyle = 'rgba(255,255,255,0.85)';
          ctx.beginPath();
          for (let i = capsule.trail.length - 2; i >= 0 && drawn < budget; i -= step) {
            if (Math.random() > (scene.lowPower ? 0.55 : 0.68)) continue;
            const p = capsule.trail[i];
            const sx = p.x + (Math.random() - 0.5) * jitter * 2;
            const sy = p.y + (Math.random() - 0.5) * jitter * 2;
            const r = (scene.lowPower ? 0.85 : 0.95) + Math.random() * 1.15;
            ctx.moveTo(sx + r, sy);
            ctx.arc(sx, sy, r, 0, TAU);
            drawn++;
          }
          ctx.fill();
          ctx.restore();
        }

        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(rot);
        ctx.globalCompositeOperation = 'lighter';

        const streakLen = s * 7.2;
        const streakW = s * 0.95;
        const streak = ctx.createLinearGradient(0, 0, -streakLen, 0);
        streak.addColorStop(0, 'rgba(255,255,255,0.26)');
        streak.addColorStop(0.08, 'rgba(255,210,140,0.20)');
        streak.addColorStop(0.18, 'rgba(59,241,255,0.18)');
        streak.addColorStop(0.42, 'rgba(255,58,168,0.14)');
        streak.addColorStop(0.70, 'rgba(122,53,255,0.10)');
        streak.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.globalAlpha = 0.98;
        ctx.fillStyle = streak;
        ctx.beginPath();
        ctx.moveTo(-s * 0.28, -streakW * 0.32);
        ctx.quadraticCurveTo(-streakLen * 0.45, -streakW * 0.12, -streakLen, 0);
        ctx.quadraticCurveTo(-streakLen * 0.45, streakW * 0.12, -s * 0.28, streakW * 0.32);
        ctx.closePath();
        ctx.fill();

        const core = ctx.createLinearGradient(-s * 0.2, 0, -streakLen * 0.86, 0);
        core.addColorStop(0, 'rgba(255,255,255,0.20)');
        core.addColorStop(0.22, 'rgba(59,241,255,0.16)');
        core.addColorStop(0.50, 'rgba(255,58,168,0.10)');
        core.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.globalAlpha = 0.55;
        ctx.strokeStyle = core;
        ctx.lineWidth = Math.max(1.1, s * 0.08);
        ctx.beginPath();
        ctx.moveTo(-s * 0.2, 0);
        ctx.lineTo(-streakLen * 0.86, 0);
        ctx.stroke();

        const pillW = s * 1.72;
        const pillH = s * 0.62;
        const r = pillH * 0.5;
        const tip = s * 0.58;

        const glow = ctx.createRadialGradient(0, 0, 2, 0, 0, s * 1.8);
        glow.addColorStop(0, 'rgba(233,232,255,0.24)');
        glow.addColorStop(0.32, 'rgba(122,53,255,0.22)');
        glow.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.globalAlpha = 0.85;
        ctx.fillStyle = glow;
        ctx.beginPath();
        ctx.ellipse(0, 0, s * 1.55, s * 1.05, 0, 0, TAU);
        ctx.fill();

        pointedCapsulePath(-pillW / 2, -pillH / 2, pillW, pillH, r, tip);
        ctx.save();
        ctx.clip();

        const left = ctx.createLinearGradient(-pillW / 2, 0, 0, 0);
        left.addColorStop(0, 'rgba(255,255,255,0.96)');
        left.addColorStop(0.55, 'rgba(233,232,255,0.88)');
        left.addColorStop(1, 'rgba(233,232,255,0.70)');
        ctx.fillStyle = left;
        ctx.fillRect(-pillW / 2 - 2, -pillH / 2 - 2, pillW / 2 + 4, pillH + 4);

        const right = ctx.createLinearGradient(0, 0, pillW / 2 + tip, 0);
        right.addColorStop(0, 'rgba(122,53,255,0.95)');
        right.addColorStop(0.52, 'rgba(182,77,255,0.78)');
        right.addColorStop(1, 'rgba(255,58,168,0.56)');
        ctx.fillStyle = right;
        ctx.fillRect(0, -pillH / 2 - 2, pillW / 2 + tip + 4, pillH + 4);
        ctx.restore();

        ctx.globalAlpha = 0.85;
        ctx.lineWidth = 1;
        ctx.strokeStyle = 'rgba(255,255,255,0.16)';
        ctx.stroke();

        ctx.globalAlpha = 0.65;
        ctx.strokeStyle = 'rgba(59,241,255,0.22)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0, -pillH * 0.48);
        ctx.lineTo(0, pillH * 0.48);
        ctx.stroke();

        const tipX = pillW / 2 + tip * 0.78;
        const speed = Math.hypot(capsule.vel.x, capsule.vel.y);
        const heat = clamp(speed / (Math.max(scene.w, scene.h) * 1.05), 0, 1);
        const plasmaX = tipX + lerp(s * 0.38, s * 0.68, heat);
        const plasmaR = lerp(s * 1.55, s * 2.05, heat);
        const plasma = ctx.createRadialGradient(plasmaX, 0, 0, plasmaX, 0, plasmaR);
        plasma.addColorStop(0, 'rgba(255,255,255,0.26)');
        plasma.addColorStop(0.10, 'rgba(255,210,140,0.22)');
        plasma.addColorStop(0.28, 'rgba(59,241,255,0.16)');
        plasma.addColorStop(0.55, 'rgba(255,58,168,0.08)');
        plasma.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.globalAlpha = lerp(0.34, 0.62, heat);
        ctx.fillStyle = plasma;
        ctx.beginPath();
        ctx.ellipse(plasmaX, 0, plasmaR * 0.95, plasmaR * 0.42, 0, 0, TAU);
        ctx.fill();

        const head = ctx.createRadialGradient(tipX, 0, 1, tipX, 0, s * 1.25);
        head.addColorStop(0, 'rgba(255,255,255,0.78)');
        head.addColorStop(0.10, 'rgba(255,210,140,0.38)');
        head.addColorStop(0.26, 'rgba(59,241,255,0.26)');
        head.addColorStop(0.50, 'rgba(255,58,168,0.18)');
        head.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.globalAlpha = 0.95;
        ctx.fillStyle = head;
        ctx.beginPath();
        ctx.ellipse(tipX, 0, s * 1.55, s * 1.05, 0, 0, TAU);
        ctx.fill();

        ctx.restore();

        const g = capsuleShadowOnGround(x, y);
        const shadowA = (1 - g.t) * 0.24;
        ctx.save();
        ctx.globalCompositeOperation = 'multiply';
        ctx.globalAlpha = shadowA;
        ctx.fillStyle = 'rgba(0,0,0,0.65)';
        ctx.beginPath();
        ctx.ellipse(g.x, g.y + 10, s * 0.78, s * 0.26, 0, 0, TAU);
        ctx.fill();
        ctx.restore();
      }

      function pointedCapsulePath(x, y, w, h, r, tip) {
        const cx = x + r;
        const right = x + w;
        const midY = y + h / 2;
        ctx.beginPath();
        ctx.moveTo(cx, y);
        ctx.lineTo(right, y);
        ctx.quadraticCurveTo(right + tip, midY, right, y + h);
        ctx.lineTo(cx, y + h);
        ctx.arc(cx, midY, r, Math.PI / 2, Math.PI * 1.5, false);
        ctx.closePath();
      }

      function roundRectPath(x, y, w, h, r) {
        const rr = Math.min(r, w / 2, h / 2);
        ctx.beginPath();
        ctx.moveTo(x + rr, y);
        ctx.arcTo(x + w, y, x + w, y + h, rr);
        ctx.arcTo(x + w, y + h, x, y + h, rr);
        ctx.arcTo(x, y + h, x, y, rr);
        ctx.arcTo(x, y, x + w, y, rr);
        ctx.closePath();
      }

      function drawImpact() {
        if (!impact.started) return;

        const w = scene.w, h = scene.h;

        if (impact.flash > 0.001) {
          ctx.save();
          ctx.globalCompositeOperation = 'lighter';
          ctx.globalAlpha = impact.flash;
          const fg = ctx.createRadialGradient(impact.x, impact.y, 0, impact.x, impact.y, Math.max(w, h) * 0.72);
          fg.addColorStop(0, 'rgba(255,255,255,0.95)');
          fg.addColorStop(0.08, 'rgba(233,232,255,0.75)');
          fg.addColorStop(0.22, 'rgba(182,77,255,0.44)');
          fg.addColorStop(0.46, 'rgba(122,53,255,0.18)');
          fg.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = fg;
          ctx.fillRect(0, 0, w, h);
          ctx.restore();
        }

        ctx.save();
        ctx.globalCompositeOperation = 'lighter';

        for (const p of impact.sparks) {
          if (p.life <= 0) continue;
          ctx.globalAlpha = p.a;
          ctx.fillStyle = p.hue === 'cyan'
            ? 'rgba(59,241,255,0.90)'
            : (p.hue === 'violet' ? 'rgba(182,77,255,0.88)' : 'rgba(122,53,255,0.86)');
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, TAU);
          ctx.fill();
        }

        ctx.globalCompositeOperation = 'source-over';
        ctx.restore();

        ctx.save();
        ctx.globalCompositeOperation = 'lighter';
        for (const d of impact.dust) {
          if (d.life <= 0) continue;
          ctx.globalAlpha = d.a;
          ctx.fillStyle = 'rgba(233,232,255,0.22)';
          ctx.beginPath();
          ctx.arc(d.x, d.y, d.r, 0, TAU);
          ctx.fill();
        }
        ctx.restore();

        const platform = ground.platform;
        const helixA = (1 - platform * 0.35) * clamp(ground.rippleStrength * 0.95, 0, 1);

        if (helixA > 0.01 && impact.helix.length) {
          ctx.save();
          ctx.globalCompositeOperation = 'lighter';
          ctx.globalAlpha = helixA;
          const baseLen = Math.min(scene.w, scene.h) * 0.26;
          for (const h0 of impact.helix) {
            const t = 1 - clamp(h0.life / 1600, 0, 1);
            const a = h0.a * (1 - t * 0.35);
            const len = baseLen * (0.6 + 0.7 * t) * h0.speed;

            ctx.lineWidth = 1;
            ctx.strokeStyle = `rgba(59,241,255,${a * 0.85})`;
            helixPath(impact.x, impact.y, len, h0.phase + scene.t * 0.003, 1);
            ctx.stroke();

            ctx.strokeStyle = `rgba(182,77,255,${a})`;
            helixPath(impact.x, impact.y, len, h0.phase + scene.t * 0.003 + Math.PI, -1);
            ctx.stroke();

            ctx.globalAlpha = helixA * 0.55;
            ctx.fillStyle = 'rgba(233,232,255,0.22)';
            for (let i = 0; i < 18; i++) {
              const u = i / 18;
              const px = impact.x + (u - 0.5) * len * 1.5;
              const py = impact.y + Math.sin(u * TAU * 2 + h0.phase) * 10 * (1 - u * 0.65);
              ctx.beginPath();
              ctx.arc(px, py, 1.3, 0, TAU);
              ctx.fill();
            }
            ctx.globalAlpha = helixA;
          }
          ctx.restore();
        }
      }

      function helixPath(cx, cy, len, phase, dir) {
        ctx.beginPath();
        const steps = 44;
        for (let i = 0; i <= steps; i++) {
          const t = i / steps;
          const x = cx + (t - 0.5) * len * 1.5;
          const amp = 14 * (1 - t * 0.75);
          const y = cy + Math.sin(t * TAU * 2 + phase) * amp * dir - t * 8;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
      }

      function updateCapsule(dt) {
        if (!capsule.active) return;

        capsule.vel.x += capsule.acc.x * dt;
        capsule.vel.y += capsule.acc.y * dt;
        capsule.pos.x += capsule.vel.x * dt;
        capsule.pos.y += capsule.vel.y * dt;
        capsule.heading = Math.atan2(capsule.vel.y, capsule.vel.x);
        const wobble = 0.10 * Math.sin(scene.t * 0.0021);
        capsule.rot = capsule.heading + wobble;

        capsule.trail.push({ x: capsule.pos.x, y: capsule.pos.y });
        if (capsule.trail.length > capsule.trailMax) capsule.trail.shift();

        const g = capsuleShadowOnGround(capsule.pos.x, capsule.pos.y);
        const hitY = g.y - 42;
        if (!impact.started && capsule.pos.y >= hitY) {
          impact.started = true;
          impact.x = g.x;
          impact.y = g.y;
          impact.wx = g.wx;
          impact.wz = g.wz;
          impact.angle = capsule.rot;
          scene.impactAt = scene.t;
          impact.elapsed = 0;
          scene.cameraShake = scene.reduced ? 0.28 : 1.0;
          capsule.active = false;
          addParticles();
        }
      }

      function updateImpact(dtMs) {
        if (!impact.started) return;

        impact.elapsed += dtMs;
        const sinceRaw = Math.max(0, scene.t - scene.impactAt);
        const t = clamp(sinceRaw / 900, 0, 1);
        const t2 = clamp(sinceRaw / IMPACT_END_MS, 0, 1);

        impact.flash = Math.max(0, (1 - easeOutExpo(t)) * 0.95);
        ground.rippleStrength = Math.min(1, Math.sqrt(Math.max(0, 1 - t2)));
        ground.platform = clamp((sinceRaw - 1200) / 1800, 0, 1);

        for (const ring of impact.rings) {
          ring.age = (ring.age || 0) + dtMs;
          const step = dtMs / 16.67;
          const maxR = ring.maxR || Math.min(scene.w, scene.h) * 0.9;
          if (ring.state === 'expand') {
            const speed = ring.shock ? 23.0 : 10.8;
            const brake = clamp(1 - ring.r / Math.max(1, maxR), 0.16, 1);
            ring.r += ring.v * step * speed * (0.38 + brake * 0.62);
            ring.a *= ring.shock ? 0.935 : 0.982;
            if (ring.r >= maxR || ring.age > (ring.shock ? 760 : 1080)) {
              ring.r = Math.min(ring.r, maxR);
              ring.state = 'hold';
              ring.holdAge = 0;
            }
          } else if (ring.state === 'hold') {
            ring.holdAge = (ring.holdAge || 0) + dtMs;
            ring.r += Math.sin(ring.holdAge * 0.018) * (ring.shock ? 0.35 : 0.22) * step;
            ring.a *= ring.shock ? 0.965 : 0.988;
            if (ring.holdAge >= (ring.hold || 120)) {
              ring.state = 'collapse';
              ring.collapse = 0.001;
            }
          } else {
            ring.collapse = clamp((ring.collapse || 0) + dtMs / (ring.shock ? 520 : 760), 0, 1);
            const pull = ring.shock ? 0.16 : 0.115;
            ring.r += (0 - ring.r) * pull * step;
            ring.a *= ring.shock ? 0.958 : 0.968;
            if (ring.r < 5 || ring.collapse >= 1) {
              ring.a = 0;
              ring.r = 0;
            }
          }
        }

        for (const p of impact.sparks) {
          if (p.life <= 0) continue;
          p.life -= dtMs;
          p.x += p.vx * (dtMs / 16.67);
          p.y += p.vy * (dtMs / 16.67);
          p.vy += 0.16 * (dtMs / 16.67);
          p.a *= 0.94;
          p.r *= 0.992;
        }

        for (const d of impact.dust) {
          if (d.life <= 0) continue;
          d.life -= dtMs;
          d.x += d.vx * (dtMs / 16.67);
          d.y += d.vy * (dtMs / 16.67);
          d.vx *= 0.988;
          d.vy *= 0.988;
          d.a *= sinceRaw > 1100 ? 0.978 : 0.988;
          if (d.a < 0.01) d.life = 0;
        }

        for (const h0 of impact.helix) h0.life -= dtMs;

        if (sinceRaw > 1400) impact.sparks.length = 0;
        if (sinceRaw > 2200) impact.dust.length = 0;

        if (!scene.revealed && sinceRaw > IMPACT_REVEAL_MS) {
          reveal();
        }
      }

      function updateCamera(dtMs) {
        scene.cameraShake = Math.max(0, scene.cameraShake - dtMs / 820);
      }

      function applyCameraTransform() {
        if (scene.reduced) return { ox: 0, oy: 0 };
        const s = scene.cameraShake;
        if (s <= 0.0001) return { ox: 0, oy: 0 };
        const p = s * s;
        const ox = (Math.random() - 0.5) * 18 * p;
        const oy = (Math.random() - 0.5) * 14 * p;
        return { ox, oy };
      }

      function introInit() {
        updateQuality();
        resize();

        capsule.active = true;
        capsule.size = Math.max(44, Math.min(66, Math.min(scene.w, scene.h) * 0.075));
        capsule.pos.x = scene.w * 0.62;
        capsule.pos.y = -scene.h * 0.18;
        capsule.vel.x = -scene.w * 0.36;
        capsule.vel.y = scene.h * 0.82;
        capsule.acc.x = 0;
        capsule.acc.y = scene.h * 0.62;
        capsule.heading = Math.atan2(capsule.vel.y, capsule.vel.x);
        capsule.rot = capsule.heading;
        capsule.rotVel = 0;
        capsule.trail.length = 0;

        impact.started = false;
        impact.elapsed = 0;
        ground.platform = 0;
        ground.rippleStrength = 0;
        scene.revealed = false;
        scene.animationStopped = false;
        document.body.classList.remove('revealed');
      }

      function reveal() {
        scene.revealed = true;
        document.body.classList.add('revealed');
        scene.revealAt = scene.t;
        impact.dust.length = 0;
        impact.sparks.length = 0;
        initScrollReveals();
        updateDna();
        initProductsFx();
      }

      function skipIntro() {
        scene.skipRequested = true;
        if (!impact.started) {
          impact.started = true;
          impact.x = scene.w * 0.5;
          impact.y = scene.h * (ground.horizonY + (1 - ground.horizonY) * 0.62);
          impact.wx = 0;
          impact.wz = 1.65;
          scene.impactAt = scene.t - IMPACT_END_MS;
          impact.elapsed = IMPACT_END_MS;
          capsule.active = false;
          addParticles();
        } else {
          scene.impactAt = scene.t - IMPACT_END_MS;
          impact.elapsed = IMPACT_END_MS;
        }
        ground.platform = 1;
        ground.rippleStrength = 0;
        impact.flash = 0;
        reveal();
      }

      function frame(now) {
        const prev = scene.t0;
        scene.t0 = now;
        scene.dt = now - prev;
        scene.t = now;

        const dtMsRaw = Math.min(48, scene.dt);
        let timeScale = 1;

        if (capsule.active) {
          const g = capsuleShadowOnGround(capsule.pos.x, capsule.pos.y);
          if (g.t > 0.78) {
            const t = clamp((g.t - 0.78) / 0.22, 0, 1);
            timeScale = Math.min(timeScale, lerp(1, 0.62, easeInOut(t)));
          }
        }

        if (impact.started && !scene.revealed) {
          const t = clamp(impact.elapsed / 1600, 0, 1);
          timeScale = Math.min(timeScale, lerp(0.26, 1, easeOutCubic(t)));
        }

        const dt = Math.min(0.045, (scene.dt / 1000) * timeScale);
        const dtMs = dtMsRaw * timeScale;

        if (!scene.revealed) updateCapsule(dt);
        updateImpact(dtMs);
        updateCamera(dtMs);

        const { ox, oy } = applyCameraTransform();

        ctx.save();
        ctx.translate(ox, oy);
        drawBackground();
        drawGround();
        drawCapsule();
        drawImpact();
        ctx.restore();

        if (scene.revealed && scene.t - scene.revealAt > 900) {
          impact.dust.length = 0;
          impact.sparks.length = 0;
          ctx.save();
          ctx.translate(ox, oy);
          drawBackground();
          drawGround();
          drawCapsule();
          drawImpact();
          ctx.restore();
          scene.animationStopped = true;
          return;
        }

        requestAnimationFrame(frame);
      }

      window.addEventListener('resize', () => {
        if (resizeRaf) return;
        resizeRaf = requestAnimationFrame(() => {
          resizeRaf = 0;
          updateQuality();
          resize();
          if (scene.animationStopped) {
            scene.animationStopped = false;
            scene.t0 = performance.now();
            requestAnimationFrame(frame);
          }
        });
      }, { passive: true });

      skipBtn.addEventListener('click', () => {
        skipIntro();
      });

      function openMaintenance() {
        lastFocus = document.activeElement;
        maintenancePop.classList.add('is-open');
        maintenancePop.setAttribute('aria-hidden', 'false');
        maintenanceClose.focus();
      }

      function closeMaintenance() {
        maintenancePop.classList.remove('is-open');
        maintenancePop.setAttribute('aria-hidden', 'true');
        if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }

      const productsData = window.__INNOGEN_PRODUCTS__ && window.__INNOGEN_PRODUCTS__.products ? window.__INNOGEN_PRODUCTS__ : null;
      let activeCategorySlug = 'all';
      let activeProductId = null;

      function updateTherapeuticCounts() {
        if (!productsData || !productsData.categories) return;
        const cards = document.querySelectorAll('.products-section .pl-card[data-cat]');
        cards.forEach(card => {
          const slug = card.getAttribute('data-cat') || '';
          const cat = productsData.categories[slug];
          if (!cat) return;
          const meta = card.querySelector('.pl-meta');
          if (!meta) return;
          const count = Number(cat.count || 0);
          meta.textContent = count + (count === 1 ? ' product' : ' products');
        });
      }
      if (productsData) updateTherapeuticCounts();

      function setProductsOpen(open) {
        if (!productsPop) return;
        productsPop.classList.toggle('is-open', !!open);
        productsPop.setAttribute('aria-hidden', open ? 'false' : 'true');
        if (!open && lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      }

      function getCategoryDisplayName(slug) {
        if (!productsData) return slug;
        if (slug === 'all') return 'All categories';
        const cat = productsData.categories && productsData.categories[slug];
        return (cat && cat.name) ? cat.name : slug;
      }

      function formatMeta(p) {
        const bits = [];
        const b = (p.brand || '').trim();
        const g = (p.generic || '').trim();
        if (b && g) bits.push(b + ' • ' + g);
        else if (b) bits.push(b);
        else if (g) bits.push(g);
        const s = (p.strength || '').trim();
        const f = (p.form || '').trim();
        if (s && f) bits.push(s + ' • ' + f);
        else if (s) bits.push(s);
        else if (f) bits.push(f);
        return bits.join(' — ');
      }

      function productMatches(p, q) {
        if (!q) return true;
        const hay = ((p.title || '') + ' ' + (p.brand || '') + ' ' + (p.generic || '') + ' ' + (p.therapeuticClass || '')).toLowerCase();
        return hay.indexOf(q) !== -1;
      }

      function productInCategory(p, catSlug) {
        if (catSlug === 'all') return true;
        const cats = p.categories || [];
        for (const c of cats) {
          if (c && c.slug === catSlug) return true;
        }
        return false;
      }

      function renderDetail(p) {
        if (!productsDetail) return;
        if (!p) {
          productsDetail.innerHTML = '<div class=\"products-empty\">Select a product to view details.</div>';
          return;
        }
        const cats = (p.categories || []).map(c => c && c.name).filter(Boolean).join(' • ');
        const img = p.image ? ('<img class=\"products-hero\" src=\"' + p.image + '\" alt=\"' + (p.title || 'Product') + '\" loading=\"lazy\" decoding=\"async\">') : '';
        const dl = p.downloadUrl ? ('<a class=\"products-download\" href=\"' + p.downloadUrl + '\" target=\"_blank\" rel=\"noopener noreferrer\">Download product information</a>') : '';
        const rows = [
          ['Brand', p.brand],
          ['Generic', p.generic],
          ['Therapeutic Class', p.therapeuticClass],
          ['Strength', p.strength],
          ['Form', p.form],
          ['Categories', cats]
        ].filter(r => (r[1] || '').toString().trim().length);

        productsDetail.innerHTML =
          '<div class=\"products-detail-inner\">' +
            img +
            '<div class=\"products-name\">' + (p.title || '') + '</div>' +
            (rows.length ? ('<dl class=\"products-kv\">' + rows.map(r => '<div class=\"products-kv-row\"><dt>' + r[0] + '</dt><dd>' + r[1] + '</dd></div>').join('') + '</dl>') : '') +
            dl +
          '</div>';
      }

      function renderList() {
        if (!productsData || !productsList) return;
        const q = (productsSearch && productsSearch.value ? productsSearch.value.trim().toLowerCase() : '');
        const items = productsData.products
          .filter(p => productInCategory(p, activeCategorySlug))
          .filter(p => productMatches(p, q))
          .sort((a, b) => (a.title || '').localeCompare((b.title || '')));

        if (!items.length) {
          productsList.innerHTML = '<div class=\"products-empty\">No products found.</div>';
          renderDetail(null);
          return;
        }

        productsList.innerHTML = items.map(p => {
          const active = (p.id === activeProductId) ? ' is-active' : '';
          const meta = formatMeta(p);
          return (
            '<button type=\"button\" class=\"products-item' + active + '\" data-pid=\"' + p.id + '\">' +
              '<div class=\"products-item-title\">' + (p.title || '') + '</div>' +
              (meta ? ('<div class=\"products-item-meta\">' + meta + '</div>') : '') +
            '</button>'
          );
        }).join('');

        const first = items[0];
        const candidate = items.find(p => p.id === activeProductId) || first;
        activeProductId = candidate ? candidate.id : null;
        renderDetail(candidate || null);
      }

      function renderCategorySelect() {
        if (!productsData || !productsCategory) return;
        const slugs = Object.keys(productsData.categories || {}).sort((a, b) => getCategoryDisplayName(a).localeCompare(getCategoryDisplayName(b)));
        const options = ['all', ...slugs].map(slug => {
          const name = getCategoryDisplayName(slug);
          const count = slug === 'all' ? (productsData.productCount || productsData.products.length) : (productsData.categories[slug] ? productsData.categories[slug].count : 0);
          return '<option value=\"' + slug + '\">' + name + ' (' + count + ')</option>';
        }).join('');
        productsCategory.innerHTML = options;
      }

      function openProductsCatalog(catSlug) {
        if (!productsData) {
          openMaintenance();
          return;
        }
        lastFocus = document.activeElement;
        activeCategorySlug = catSlug || 'all';
        activeProductId = null;
        renderCategorySelect();
        if (productsCategory) productsCategory.value = activeCategorySlug;
        if (productsSearch) productsSearch.value = '';
        renderList();
        setProductsOpen(true);
        if (productsSearch) productsSearch.focus();
      }

      document.addEventListener('click', event => {
        const link = event.target.closest && event.target.closest('a[data-maintenance="true"]');
        if (!link) return;
        event.preventDefault();
        openMaintenance();
      });

      document.addEventListener('click', event => {
        const link = event.target.closest && event.target.closest('a[data-open-products]');
        if (!link) return;
        event.preventDefault();
        openProductsCatalog('all');
      });

      document.addEventListener('click', event => {
        const card = event.target.closest && event.target.closest('.products-section .pl-card[data-cat]');
        if (!card) return;
        openProductsCatalog(card.getAttribute('data-cat') || 'all');
      });

      document.addEventListener('keydown', event => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        const card = event.target && event.target.closest && event.target.closest('.products-section .pl-card[data-cat]');
        if (!card) return;
        event.preventDefault();
        openProductsCatalog(card.getAttribute('data-cat') || 'all');
      });

      maintenanceClose.addEventListener('click', () => {
        closeMaintenance();
      });

      maintenancePop.addEventListener('click', event => {
        if (event.target === maintenancePop) closeMaintenance();
      });

      if (productsClose) {
        productsClose.addEventListener('click', () => {
          setProductsOpen(false);
        });
      }

      if (productsPop) {
        productsPop.addEventListener('click', event => {
          if (event.target === productsPop) setProductsOpen(false);
        });
      }

      if (productsList) {
        productsList.addEventListener('click', event => {
          const btn = event.target.closest && event.target.closest('.products-item[data-pid]');
          if (!btn) return;
          const pid = parseInt(btn.getAttribute('data-pid'), 10);
          if (!Number.isFinite(pid)) return;
          activeProductId = pid;
          renderList();
        });
      }

      if (productsCategory) {
        productsCategory.addEventListener('change', () => {
          activeCategorySlug = productsCategory.value || 'all';
          activeProductId = null;
          renderList();
        });
      }

      if (productsSearch) {
        productsSearch.addEventListener('input', () => {
          activeProductId = null;
          renderList();
        });
      }

      window.addEventListener('keydown', event => {
        if (event.key !== 'Escape') return;
        if (productsPop && productsPop.classList.contains('is-open')) {
          setProductsOpen(false);
          return;
        }
        if (maintenancePop.classList.contains('is-open')) closeMaintenance();
      });

      let productsFxInit = false;
      let scrollRaf = 0;
      let sunriseValue = 0;
      let sunriseFlicker = false;
      let revealObs = null;
      let dnaValue = 0;
      let dnaBuilt = false;
      let themesInit = false;
      let activeSectionId = '';
      let themeCooldownUntil = 0;
      const coarsePointer = !!(window.matchMedia && window.matchMedia('(pointer: coarse)').matches);
      let themedSections = null;
      let parallaxRaf = 0;
      let pxT = 0, pyT = 0;
      let pxV = 0, pyV = 0;

      function setSunrise(v) {
        sunriseValue = v;
        document.documentElement.style.setProperty('--sunrise', v.toFixed(3));
        const vignette = (v < 0.5 ? v * 2 : (1 - v) * 2) * 0.55;
        document.documentElement.style.setProperty('--vignette', vignette.toFixed(3));
      }

      function initProductsFx() {
        if (productsFxInit) return;
        productsFxInit = true;
        if (scene.reduced) return;

        const cards = Array.from(document.querySelectorAll('.products-section .pl-card'));
        if (!cards.length) return;

        const coarse = !!(window.matchMedia && window.matchMedia('(pointer: coarse)').matches);

        for (const card of cards) {
          const img = card.querySelector('img');
          if (!img) continue;

          let hovering = false;
          let rafId = 0;
          let tEnter = 0;
          let lastT = 0;
          let tx = 0, ty = 0;
          let txT = 0, tyT = 0;

          function draw(now) {
            if (!hovering) { rafId = 0; return; }
            const dt = Math.min(32, (now - lastT) || 16.67);
            lastT = now;

            const elapsed = Math.max(0, now - tEnter);
            const zoom = 1.02 + Math.min(1, elapsed / 6500) * 0.12;

            const k = 1 - Math.pow(0.001, dt / 16.67);
            tx += (txT - tx) * k;
            ty += (tyT - ty) * k;

            const maxShift = 14;
            img.style.transform =
              'translate3d(' + (tx * maxShift).toFixed(2) + 'px,' +
              (ty * maxShift).toFixed(2) + 'px,0) scale(' + zoom.toFixed(3) + ')';

            rafId = requestAnimationFrame(draw);
          }

          function stop() {
            hovering = false;
            tx = 0; ty = 0;
            txT = 0; tyT = 0;
            card.classList.remove('is-active');
            img.style.transform = 'translate3d(0,0,0) scale(1)';
          }

          function start() {
            hovering = true;
            tEnter = performance.now();
            lastT = 0;
            card.classList.add('is-active');
            if (!rafId) rafId = requestAnimationFrame(draw);
          }

          function updateTargetFromEvent(event) {
            const r = card.getBoundingClientRect();
            const x = (event.clientX - r.left) / Math.max(1, r.width);
            const y = (event.clientY - r.top) / Math.max(1, r.height);
            txT = -(x - 0.5);
            tyT = -(y - 0.5) * 0.85;
          }

          if (!coarse) {
            card.addEventListener('pointerenter', () => {
              start();
            }, { passive: true });

            card.addEventListener('pointermove', event => {
              updateTargetFromEvent(event);
            }, { passive: true });

            card.addEventListener('pointerleave', () => {
              stop();
            }, { passive: true });

            continue;
          }

          let active = false;
          let pointerId = null;
          let lastMoveAt = 0;

          card.addEventListener('contextmenu', event => {
            event.preventDefault();
          });

          card.addEventListener('pointerdown', event => {
            if (event.pointerType !== 'touch') return;
            active = true;
            pointerId = event.pointerId;
            lastMoveAt = performance.now();
            updateTargetFromEvent(event);
            start();
            try { card.setPointerCapture(pointerId); } catch (_) {}
          }, { passive: true });

          card.addEventListener('pointermove', event => {
            if (!active) return;
            if (pointerId !== null && event.pointerId !== pointerId) return;
            lastMoveAt = performance.now();
            updateTargetFromEvent(event);
          }, { passive: true });

          card.addEventListener('pointerup', event => {
            if (!active) return;
            if (pointerId !== null && event.pointerId !== pointerId) return;
            active = false;
            pointerId = null;
            stop();
          }, { passive: true });

          card.addEventListener('lostpointercapture', () => {
            if (!active) return;
            active = false;
            pointerId = null;
            stop();
          }, { passive: true });

          window.addEventListener('scroll', () => {
            if (!active) return;
            const idleFor = performance.now() - lastMoveAt;
            if (idleFor < 120) return;
            active = false;
            pointerId = null;
            stop();
          }, { passive: true });

          card.addEventListener('pointercancel', () => {
            active = false;
            pointerId = null;
            stop();
          }, { passive: true });
        }
      }

      function setDna(v) {
        dnaValue = v;
        const el = document.getElementById('dna');
        if (!el) return;
        el.style.setProperty('--dna', v.toFixed(3));
      }

      function buildDnaHelix() {
        if (dnaBuilt) return;
        const mount = document.getElementById('dnaRender');
        if (!mount) return;
        dnaBuilt = true;

        const svgNS = 'http://www.w3.org/2000/svg';
        const W = 600;
        const top = 26;
        const bottom = 294;
        const center = 300;
        const amp = 118;
        const steps = 20;

        function el(name) {
          return document.createElementNS(svgNS, name);
        }

        function fmt(n) {
          return (Math.round(n * 1000) / 1000).toString();
        }

        const leftPts = [];
        const rightPts = [];

        for (let i = 0; i < steps; i++) {
          const t = steps <= 1 ? 0 : i / (steps - 1);
          const y = top + (bottom - top) * t;
          const a = i * 0.62;
          const s = Math.sin(a);
          const c = Math.cos(a);

          const xL = center - s * amp;
          const xR = center + s * amp;

          leftPts.push([xL, y]);
          rightPts.push([xR, y]);

          const depth = (c + 1) * 0.5;
          const pair = el('line');
          pair.setAttribute('x1', fmt(xL));
          pair.setAttribute('y1', fmt(y));
          pair.setAttribute('x2', fmt(xR));
          pair.setAttribute('y2', fmt(y));
          pair.setAttribute('class', 'base-pair ' + (i % 4 === 0 ? 'adenine' : i % 4 === 1 ? 'thymine' : i % 4 === 2 ? 'cytosine' : 'guanine'));
          pair.setAttribute('opacity', fmt(0.36 + depth * 0.60));
          mount.appendChild(pair);

          const r = 4.8 + depth * 3.4;
          const sx = 0.92 + depth * 0.12;

          const nodeL = el('circle');
          nodeL.setAttribute('class', 'node');
          nodeL.setAttribute('cx', fmt(xL));
          nodeL.setAttribute('cy', fmt(y));
          nodeL.setAttribute('r', fmt(r));
          nodeL.setAttribute('fill', 'rgba(59,241,255,0.92)');
          nodeL.setAttribute('fill-opacity', fmt(0.34 + depth * 0.64));
          nodeL.setAttribute('transform', 'translate(' + fmt(xL) + ' ' + fmt(y) + ') scale(' + fmt(sx) + ') translate(' + fmt(-xL) + ' ' + fmt(-y) + ')');
          mount.appendChild(nodeL);

          const glossL = el('circle');
          glossL.setAttribute('class', 'node-overlay');
          glossL.setAttribute('cx', fmt(xL));
          glossL.setAttribute('cy', fmt(y));
          glossL.setAttribute('r', fmt(r));
          glossL.setAttribute('fill', 'url(#sphereGrad)');
          glossL.setAttribute('fill-opacity', fmt(0.22 + depth * 0.34));
          glossL.setAttribute('transform', nodeL.getAttribute('transform'));
          mount.appendChild(glossL);

          const nodeR = el('circle');
          nodeR.setAttribute('class', 'node');
          nodeR.setAttribute('cx', fmt(xR));
          nodeR.setAttribute('cy', fmt(y));
          nodeR.setAttribute('r', fmt(r));
          nodeR.setAttribute('fill', 'rgba(255,58,168,0.90)');
          nodeR.setAttribute('fill-opacity', fmt(0.34 + (1 - depth) * 0.64));
          nodeR.setAttribute('transform', 'translate(' + fmt(xR) + ' ' + fmt(y) + ') scale(' + fmt(0.92 + (1 - depth) * 0.12) + ') translate(' + fmt(-xR) + ' ' + fmt(-y) + ')');
          mount.appendChild(nodeR);

          const glossR = el('circle');
          glossR.setAttribute('class', 'node-overlay');
          glossR.setAttribute('cx', fmt(xR));
          glossR.setAttribute('cy', fmt(y));
          glossR.setAttribute('r', fmt(r));
          glossR.setAttribute('fill', 'url(#sphereGrad)');
          glossR.setAttribute('fill-opacity', fmt(0.22 + (1 - depth) * 0.34));
          glossR.setAttribute('transform', nodeR.getAttribute('transform'));
          mount.appendChild(glossR);
        }

        function pathFromPts(pts) {
          let d = '';
          for (let i = 0; i < pts.length; i++) {
            const p = pts[i];
            d += (i === 0 ? 'M' : 'L') + fmt(p[0]) + ' ' + fmt(p[1]);
          }
          return d;
        }

        const leftD = pathFromPts(leftPts);
        const rightD = pathFromPts(rightPts);

        const glowA = el('path');
        glowA.setAttribute('class', 'backbone glow');
        glowA.setAttribute('d', leftD);
        mount.insertBefore(glowA, mount.firstChild);

        const glowB = el('path');
        glowB.setAttribute('class', 'backbone glow');
        glowB.setAttribute('d', rightD);
        mount.insertBefore(glowB, mount.firstChild);

        const coreA = el('path');
        coreA.setAttribute('class', 'backbone core');
        coreA.setAttribute('d', leftD);
        mount.insertBefore(coreA, mount.firstChild);

        const coreB = el('path');
        coreB.setAttribute('class', 'backbone core');
        coreB.setAttribute('d', rightD);
        mount.insertBefore(coreB, mount.firstChild);
      }

      function initScrollReveals() {
        if (revealObs || scene.reduced) return;
        const items = Array.from(document.querySelectorAll('.reveal-on-scroll'));
        if (!items.length) return;
        revealObs = new IntersectionObserver(entries => {
          for (const e of entries) {
            if (e.isIntersecting) e.target.classList.add('is-visible');
          }
        }, { root: null, rootMargin: '0px 0px -12% 0px', threshold: 0.08 });
        for (const el of items) revealObs.observe(el);
        requestAnimationFrame(() => {
          for (const el of items) {
            const r = el.getBoundingClientRect();
            if (r.top < innerHeight * 0.92 && r.bottom > innerHeight * 0.08) el.classList.add('is-visible');
          }
        });
      }

      function applySectionTheme(next) {
        if (!next || next === activeSectionId) return;
        const now = performance.now();
        if (coarsePointer && now < themeCooldownUntil) return;
        if (coarsePointer) themeCooldownUntil = now + 420;
        const root = document.documentElement;
        activeSectionId = next;
        root.dataset.activeSection = next;

        const bgMap = {
          about: 'radial-gradient(1200px 860px at 65% 20%, rgba(122,53,255,0.12), transparent 58%), radial-gradient(900px 700px at 22% 70%, rgba(59,241,255,0.08), transparent 62%), linear-gradient(180deg, rgba(10,9,24,0.22), rgba(7,7,18,0.00))',
          products: 'radial-gradient(980px 720px at 60% 18%, rgba(59,241,255,0.14), transparent 62%), radial-gradient(860px 720px at 20% 72%, rgba(255,58,168,0.10), transparent 64%), linear-gradient(180deg, rgba(12,14,36,0.20), rgba(7,7,18,0.00))',
          quality: 'radial-gradient(1100px 860px at 70% 22%, rgba(59,241,255,0.12), transparent 62%), radial-gradient(900px 800px at 26% 78%, rgba(122,53,255,0.12), transparent 66%), linear-gradient(180deg, rgba(8,14,26,0.22), rgba(7,7,18,0.00))',
          how: 'radial-gradient(980px 720px at 62% 24%, rgba(182,77,255,0.12), transparent 60%), radial-gradient(860px 720px at 22% 74%, rgba(255,58,168,0.09), transparent 66%), linear-gradient(180deg, rgba(12,10,32,0.22), rgba(7,7,18,0.00))',
          contact: 'radial-gradient(980px 720px at 58% 18%, rgba(255,210,140,0.12), transparent 64%), radial-gradient(860px 720px at 18% 76%, rgba(59,241,255,0.08), transparent 66%), linear-gradient(180deg, rgba(10,9,24,0.22), rgba(7,7,18,0.00))'
        };

        const capMap = {
          about: 'none',
          products: 'var(--capsule-bg-tablets-dense)',
          quality: 'none',
          how: 'var(--capsule-bg-tablets-dense)',
          contact: 'var(--capsule-bg)'
        };

        const bgA = getComputedStyle(root).getPropertyValue('--section-bg-b').trim() || bgMap.about;
        root.style.setProperty('--section-bg-a', bgA);
        root.style.setProperty('--section-bg-b', bgMap[next] || bgMap.about);
        root.style.setProperty('--section-bg-mix', '0');
        requestAnimationFrame(() => root.style.setProperty('--section-bg-mix', '1'));

        const capA = getComputedStyle(root).getPropertyValue('--capsule-b').trim() || 'var(--capsule-bg)';
        root.style.setProperty('--capsule-a', capA);
        root.style.setProperty('--capsule-b', capMap[next] || 'var(--capsule-bg)');
        if (next === 'about') {
          root.style.setProperty('--capsule-size', '980px');
          root.style.setProperty('--capsule-repeat', 'no-repeat');
          root.style.setProperty('--capsule-pos-x', '52%');
          root.style.setProperty('--capsule-pos-y', '40%');
          root.style.setProperty('--capsule-mask', 'linear-gradient(to bottom, rgba(0,0,0,0.06) 0%, rgba(0,0,0,0.85) 48%, rgba(0,0,0,1) 100%)');
        } else {
          root.style.setProperty('--capsule-size', '520px');
          root.style.setProperty('--capsule-repeat', 'repeat');
          root.style.setProperty('--capsule-pos-x', '50%');
          root.style.setProperty('--capsule-pos-y', '62%');
          root.style.setProperty('--capsule-mask', 'linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.22) 28%, rgba(0,0,0,1) 64%, rgba(0,0,0,1) 100%)');
        }
        root.style.setProperty('--capsule-mix', '0');
        requestAnimationFrame(() => root.style.setProperty('--capsule-mix', '1'));
      }

      function updateActiveSectionFromScroll() {
        if (!themesInit || !themedSections || !themedSections.length) return;
        const mid = innerHeight * 0.5;
        let best = null;
        let bestD = Infinity;
        for (const s of themedSections) {
          if (!s) continue;
          const r = s.getBoundingClientRect();
          if (r.bottom <= 0 || r.top >= innerHeight) continue;
          if (r.top <= mid && r.bottom >= mid) {
            best = s;
            bestD = -1;
            break;
          }
          const d = Math.abs((r.top + r.bottom) * 0.5 - mid);
          if (d < bestD) { bestD = d; best = s; }
        }
        if (best && best.id) applySectionTheme(best.id);
      }

      function initSectionThemes() {
        if (themesInit) return;
        themesInit = true;
        const ids = ['about', 'products', 'quality', 'how', 'contact'];
        const sections = ids.map(id => document.getElementById(id)).filter(Boolean);
        if (!sections.length) return;
        themedSections = sections;

        const obs = new IntersectionObserver(entries => {
          let intersects = false;
          for (const e of entries) {
            if (e.isIntersecting) { intersects = true; break; }
          }
          if (intersects) updateActiveSectionFromScroll();
        }, { root: null, rootMargin: '-45% 0px -45% 0px', threshold: [0, 0.1, 0.2, 0.35, 0.5, 0.65] });

        for (const s of sections) obs.observe(s);

        requestAnimationFrame(() => {
          updateActiveSectionFromScroll();
        });

        if (!coarsePointer) {
          window.addEventListener('pointermove', event => {
            const nx = (event.clientX / Math.max(1, innerWidth)) * 2 - 1;
            const ny = (event.clientY / Math.max(1, innerHeight)) * 2 - 1;
            pxT = nx;
            pyT = ny;
            if (parallaxRaf) return;
            parallaxRaf = requestAnimationFrame(() => {
              parallaxRaf = 0;
              const k = 0.11;
              pxV += (pxT - pxV) * k;
              pyV += (pyT - pyV) * k;
              const mx = (pxV * 14).toFixed(2) + 'px';
              const my = (pyV * 10).toFixed(2) + 'px';
              document.documentElement.style.setProperty('--parallax-x', mx);
              document.documentElement.style.setProperty('--parallax-y', my);
            });
          }, { passive: true });
        }
      }

      function updateDna() {
        const el = document.getElementById('dna');
        if (!el) return;
        if (!document.body.classList.contains('revealed')) {
          setDna(0);
          return;
        }

        buildDnaHelix();

        if (scene.reduced) {
          setDna(1);
          return;
        }
        const r = el.getBoundingClientRect();
        const start = innerHeight * 0.92;
        const end = -r.height * 0.20;
        const t = clamp((start - r.top) / Math.max(1, start - end), 0, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        setDna(eased);
      }

      function updateSunrise() {
        if (!document.body.classList.contains('revealed')) {
          setSunrise(0);
          return;
        }
        if (sunriseFlicker) return;
        const about = document.getElementById('about');
        if (!about) {
          const maxScroll = Math.max(1, document.documentElement.scrollHeight - innerHeight);
          const t = clamp(scrollY / maxScroll, 0, 1);
          const eased = t * t * (3 - 2 * t);
          setSunrise(eased);
          return;
        }

        const aboutY = about.getBoundingClientRect().top + scrollY;
        const startY = aboutY - innerHeight * 1.55;
        const endY = aboutY - innerHeight * 1.15;
        const t = clamp((scrollY - startY) / Math.max(1, endY - startY), 0, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        setSunrise(eased);

        const topThreshold = 220;
        if (scrollY <= topThreshold && sunriseValue > 0.18) {
          sunriseFlicker = true;
          const t0 = performance.now();
          const k = [
            [0, Math.min(1, sunriseValue * 0.55)],
            [90, 0.02],
            [160, 0.26],
            [240, 0.00],
            [320, 0.10],
            [420, 0.00]
          ];
          function step(now) {
            const dt = now - t0;
            let v = 0;
            for (let i = 0; i < k.length - 1; i++) {
              const a = k[i], b = k[i + 1];
              if (dt >= a[0] && dt <= b[0]) {
                const u = (dt - a[0]) / Math.max(1, b[0] - a[0]);
                v = lerp(a[1], b[1], u);
                break;
              }
              if (dt > b[0]) v = b[1];
            }
            setSunrise(v);
            if (dt < k[k.length - 1][0]) {
              requestAnimationFrame(step);
              return;
            }
            sunriseFlicker = false;
            setSunrise(0);
          }
          requestAnimationFrame(step);
        }
      }

      window.addEventListener('scroll', () => {
        if (scrollRaf) return;
        scrollRaf = requestAnimationFrame(() => {
          scrollRaf = 0;
          updateSunrise();
          updateDna();
          updateActiveSectionFromScroll();
        });
      }, { passive: true });

      function forceRevealStatic() {
        updateQuality();
        resize();
        capsule.active = false;
        impact.started = false;
        scene.revealed = true;
        document.body.classList.add('revealed');
        const now = performance.now();
        scene.t0 = now;
        scene.t = now;
        scene.revealAt = now - 1000;
        scene.animationStopped = true;
        initScrollReveals();
        initSectionThemes();
        updateDna();
        initProductsFx();
      }

      function start() {
        const deepLink = !!(location.hash && location.hash !== '#');
        const restoredScroll = scrollY > 4;

        if (deepLink || restoredScroll) {
          forceRevealStatic();
          updateSunrise();
          updateDna();
          requestAnimationFrame(frame);
          return;
        }

        updateSunrise();
        updateDna();
        introInit();
        initScrollReveals();
        initSectionThemes();
        requestAnimationFrame(frame);
      }

      window.addEventListener('pageshow', () => {
        requestAnimationFrame(() => {
          if ((location.hash && location.hash !== '#') || scrollY > 4) {
            forceRevealStatic();
            updateSunrise();
            updateDna();
          }
        });
      });

      window.addEventListener('keydown', event => {
        if ((event.ctrlKey || event.metaKey) && (event.key === 'b' || event.key === 'B')) {
          const root = document.documentElement;
          root.dataset.capsuleTheme = root.dataset.capsuleTheme === 'classic' ? 'future' : 'classic';
        }
      });

      requestAnimationFrame(start);
    })();
  </script>

  <script>
    (() => {
      const reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      const pc = document.getElementById('particles');
      const px = pc.getContext('2d', { alpha: true });
      const TAU = Math.PI * 2;
      const DPR = Math.min(window.devicePixelRatio || 1, 1.6);

      const lowPower = (
        (window.matchMedia && window.matchMedia('(pointer: coarse)').matches) ||
        (navigator.hardwareConcurrency && navigator.hardwareConcurrency <= 4) ||
        (navigator.deviceMemory && navigator.deviceMemory <= 2) ||
        Math.min(innerWidth, innerHeight) < 480
      );

      const COUNT      = lowPower ? 38  : 72;
      const ORB_COUNT  = lowPower ? 3   : 6;
      const TRAIL_LEN  = lowPower ? 0   : 10;
      const GLOW_BLUR  = lowPower ? 0   : 9;

      let W = 0, H = 0;

      function resize() {
        W = innerWidth;
        H = innerHeight;
        pc.width  = Math.floor(W * DPR);
        pc.height = Math.floor(H * DPR);
        px.setTransform(1,0,0,1,0,0);
        px.scale(DPR, DPR);
      }
      resize();
      window.addEventListener('resize', resize, { passive: true });

      const COLS = [
        { r:122, g:53,  b:255 },
        { r:182, g:77,  b:255 },
        { r:59,  g:241, b:255 },
        { r:255, g:58,  b:168 },
        { r:233, g:232, b:255 },
      ];
      function col(c, a) {
        return 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',' + a.toFixed(3) + ')';
      }

      const rand = (a, b) => a + Math.random() * (b - a);

      function makeDot() {
        const c = COLS[Math.floor(Math.random() * COLS.length)];
        const bx = rand(0, W);
        return {
          bx,
          x:        bx,
          y:        rand(H * 0.1, H),
          vy:       rand(-0.12, -0.042),
          vxAmp:    rand(0.06, 0.22),
          vxFreq:   rand(0.00028, 0.00072),
          phase:    rand(0, TAU),
          size:     rand(0.9, 2.8),
          alpha:    rand(0.12, 0.48),
          alphaDir: Math.random() > 0.5 ? 1 : -1,
          alphaSpeed: rand(0.0003, 0.0009),
          alphaMin: rand(0.06, 0.16),
          alphaMax: rand(0.28, 0.52),
          c,
          trail:    TRAIL_LEN > 0 ? [] : null,
          _lastT:   0,
        };
      }

      const dots = Array.from({ length: COUNT }, makeDot);

      function makeOrb(i) {
        const c = COLS[i % COLS.length];
        const r = rand(90, 220);
        return {
          x:      rand(W * 0.1, W * 0.9),
          y:      rand(H * 0.15, H * 0.85),
          r,
          rBase:  r,
          rPulse: rand(18, 55),
          rFreq:  rand(0.00018, 0.00042),
          phase:  rand(0, TAU),
          vx:     rand(-0.018, 0.018),
          vy:     rand(-0.012, 0.012),
          alpha:  rand(0.022, 0.065),
          c,
        };
      }

      const orbs = Array.from({ length: ORB_COUNT }, (_, i) => makeOrb(i));

      const CONNECT_DIST = lowPower ? 0 : 110;
      const CONNECT_DIST2 = CONNECT_DIST * CONNECT_DIST;

      let mouseX = -9999;
      let mouseY = -9999;
      let mouseActive = false;
      const MOUSE_R = lowPower ? 120 : 170;
      const MOUSE_R2 = MOUSE_R * MOUSE_R;
      const MOUSE_PUSH = lowPower ? 0.006 : 0.010;

      let modeV = 0;

      window.addEventListener('pointermove', event => {
        mouseX = event.clientX;
        mouseY = event.clientY;
        mouseActive = true;
      }, { passive: true });

      window.addEventListener('pointerleave', () => {
        mouseActive = false;
      }, { passive: true });

      let running = false;
      let rafId   = 0;
      let t0      = 0;
      let lastDrawAt = 0;

      const root = document.documentElement;
      function wantsParticles() {
        if (!document.body.classList.contains('revealed')) return true;
        const active = root.dataset.activeSection || '';
        return active === 'products' || active === 'quality' || active === 'how';
      }

      const OPACITY_MAP = {
        intro: 0.82,
        about: 0.18,
        products: 0.26,
        quality: 0.18,
        how: 0.22,
        contact: 0.12,
      };

      function desiredOpacity() {
        if (!document.body.classList.contains('revealed')) return OPACITY_MAP.intro;
        const active = root.dataset.activeSection || '';
        return OPACITY_MAP[active] ?? 0.14;
      }

      function applyOpacity() {
        root.style.setProperty('--particles-opacity', desiredOpacity().toFixed(3));
      }

      function drawFrame(now) {
        const minFrameMs = lowPower ? 50 : 33;
        if (now - lastDrawAt < minFrameMs) {
          rafId = requestAnimationFrame(drawFrame);
          return;
        }
        const dtMs = Math.min(66, Math.max(0, now - lastDrawAt || minFrameMs));
        lastDrawAt = now;

        const t = now - t0;
        px.clearRect(0, 0, W, H);

        const active = document.documentElement.dataset.activeSection || '';
        let targetMode = 0;
        if (active === 'products' || active === 'how') targetMode = 1;
        if (active === 'quality') targetMode = 2;
        modeV += (targetMode - modeV) * 0.06;
        const strand = Math.max(0, Math.min(1, modeV / 2));

        for (const o of orbs) {
          o.x += o.vx * (dtMs / 16.67);
          o.y += o.vy * (dtMs / 16.67);
          if (o.x < -o.r)    o.x = W + o.r;
          if (o.x > W + o.r) o.x = -o.r;
          if (o.y < -o.r)    o.y = H + o.r;
          if (o.y > H + o.r) o.y = -o.r;
          o.r = o.rBase + Math.sin(t * o.rFreq + o.phase) * o.rPulse;
          const g = px.createRadialGradient(o.x, o.y, 0, o.x, o.y, o.r);
          g.addColorStop(0,   col(o.c, o.alpha));
          g.addColorStop(0.5, col(o.c, o.alpha * 0.38));
          g.addColorStop(1,   col(o.c, 0));
          px.fillStyle = g;
          px.beginPath();
          px.arc(o.x, o.y, o.r, 0, TAU);
          px.fill();
        }

        if (GLOW_BLUR > 0) px.shadowBlur = GLOW_BLUR;
        px.lineCap = 'round';

        for (let i = 0; i < dots.length; i++) {
          const d = dots[i];
          const elapsed = d._lastT ? now - d._lastT : 16;
          d._lastT = now;

          const step = Math.min(60, Math.max(1, elapsed)) / 16.67;
          d.x = d.bx + d.vxAmp * Math.sin(t * d.vxFreq + d.phase);
          d.y += d.vy * step;

          if (mouseActive) {
            const dxm = d.x - mouseX;
            const dym = d.y - mouseY;
            const dist2m = dxm * dxm + dym * dym;
            if (dist2m < MOUSE_R2) {
              const force = (1 - dist2m / MOUSE_R2) * MOUSE_PUSH * (elapsed / 16.67);
              d.bx += dxm * force;
              d.y += dym * force;
            }
          }

          d.alpha += d.alphaDir * d.alphaSpeed * elapsed;
          if (d.alpha > d.alphaMax) { d.alpha = d.alphaMax; d.alphaDir = -1; }
          if (d.alpha < d.alphaMin) { d.alpha = d.alphaMin; d.alphaDir =  1; }

          if (d.y < -12) {
            const fresh = makeDot();
            fresh.bx = rand(0, W);
            fresh.x = fresh.bx;
            fresh.y = H + 8;
            dots[i] = fresh;
            continue;
          }

          const trailsOn = !!(d.trail && strand > 0.08);
          if (d.trail && !trailsOn) d.trail.length = 0;
          if (trailsOn) {
            if (elapsed > 80) d.trail.length = 0;
            d.trail.push({ x: d.x, y: d.y });
            if (d.trail.length > TRAIL_LEN) d.trail.shift();
            if (d.trail.length > 1) {
              for (let k = 1; k < d.trail.length; k++) {
                const prog   = k / d.trail.length;
                const tAlpha = d.alpha * prog * (0.45 + strand * 0.35);
                px.strokeStyle = col(d.c, tAlpha);
                px.lineWidth   = d.size * prog * (0.6 + strand * 0.38);
                px.shadowColor = col(d.c, tAlpha * 0.5);
                px.beginPath();
                px.moveTo(d.trail[k-1].x, d.trail[k-1].y);
                px.lineTo(d.trail[k].x,   d.trail[k].y);
                px.stroke();
              }
            }
          }

        if (CONNECT_DIST > 0 && strand > 0.02) {
            for (let j = i + 1; j < dots.length; j++) {
              const e  = dots[j];
              const dx = d.x - e.x;
              const dy = d.y - e.y;
              const dist2 = dx * dx + dy * dy;
              if (dist2 < CONNECT_DIST2) {
                const dist = Math.sqrt(dist2);
                const prog      = 1 - dist / CONNECT_DIST;
                const lineAlpha = prog * prog * (0.10 + strand * 0.16);
                px.strokeStyle = col(d.c, lineAlpha);
                px.lineWidth   = 0.6 + strand * 0.9;
                px.shadowBlur  = 0;
                px.shadowColor = 'transparent';
                px.beginPath();
                px.moveTo(d.x, d.y);
                px.lineTo(e.x, e.y);
                px.stroke();
                if (GLOW_BLUR > 0) px.shadowBlur = GLOW_BLUR;
              }
            }
          }

          px.shadowColor = col(d.c, d.alpha * 0.7);
          px.fillStyle   = col(d.c, d.alpha);
          px.beginPath();
          px.arc(d.x, d.y, d.size, 0, TAU);
          px.fill();
        }

        px.shadowBlur  = 0;
        px.shadowColor = 'transparent';

        rafId = requestAnimationFrame(drawFrame);
      }

      function startParticles() {
        if (running) return;
        running = true;
        t0 = performance.now();
        lastDrawAt = 0;
        dots.forEach(d => {
          d.bx = rand(0, W);
          d.x = d.bx;
          d.y = rand(0, H);
          d._lastT = 0;
          if (d.trail) d.trail.length = 0;
        });
        rafId = requestAnimationFrame(drawFrame);
      }

      function stopParticles(clear = true) {
        running = false;
        cancelAnimationFrame(rafId);
        if (clear) px.clearRect(0, 0, W, H);
      }

      const obs = new MutationObserver(() => {
        applyOpacity();
        if (document.body.classList.contains('revealed')) {
          if (wantsParticles()) startParticles();
        } else {
          if (wantsParticles()) startParticles();
          else stopParticles(true);
        }
      });
      obs.observe(document.body, { attributes: true, attributeFilter: ['class'] });

      const sectionObs = new MutationObserver(() => {
        applyOpacity();
        if (wantsParticles()) startParticles();
        else stopParticles(true);
      });
      sectionObs.observe(root, { attributes: true, attributeFilter: ['data-active-section'] });

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          stopParticles(false);
        } else {
          applyOpacity();
          if (wantsParticles()) startParticles();
        }
      });

      let idleTimer = 0;
      function armIdleStop() {
        clearTimeout(idleTimer);
        idleTimer = setTimeout(() => {
          stopParticles(false);
        }, 10000);
      }

      function onScrollActivity() {
        applyOpacity();
        if (wantsParticles()) startParticles();
        armIdleStop();
      }

      window.addEventListener('scroll', onScrollActivity, { passive: true });
      window.addEventListener('pointermove', () => {
        if (!running) return;
        armIdleStop();
      }, { passive: true });

      applyOpacity();
      if (wantsParticles()) startParticles();
      armIdleStop();
    })();
  </script>
</body>
</html>
