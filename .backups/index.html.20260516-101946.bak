    }

    html{
      --capsule-bg-future-clean: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='420'%20height='420'%20viewBox='0%200%20420%20420'%3E%3Cdefs%3E%3ClinearGradient%20id='t1'%20x1='0'%20y1='0'%20x2='1'%20y2='1'%3E%3Cstop%20offset='0'%20stop-color='%23ffffff'%20stop-opacity='0.22'/%3E%3Cstop%20offset='0.55'%20stop-color='%233bf1ff'%20stop-opacity='0.18'/%3E%3Cstop%20offset='1'%20stop-color='%237a35ff'%20stop-opacity='0.16'/%3E%3C/linearGradient%3E%3CradialGradient%20id='p1'%20cx='30%25'%20cy='30%25'%20r='75%25'%3E%3Cstop%20offset='0'%20stop-color='%23ffffff'%20stop-opacity='0.22'/%3E%3Cstop%20offset='1'%20stop-color='%23ff3aa8'%20stop-opacity='0.14'/%3E%3C/radialGradient%3E%3C/defs%3E%3Crect%20width='420'%20height='420'%20fill='none'/%3E%3Cg%20fill='none'%20stroke='%23ffffff'%20stroke-opacity='0.08'%3E%3Cpath%20d='M56%20118h124'%20/%3E%3Cpath%20d='M72%20294h140'%20/%3E%3C/g%3E%3Cg%20transform='translate(32%2066)%20rotate(-16%20160%2090)'%3E%3Crect%20x='90'%20y='60'%20width='210'%20height='92'%20rx='46'%20fill='url(%23t1)'%20stroke='%23ffffff'%20stroke-opacity='0.12'/%3E%3Cpath%20d='M195%2060v92'%20stroke='%23ffffff'%20stroke-opacity='0.14'/%3E%3C/g%3E%3Cg%20transform='translate(40%20236)%20rotate(12%20160%2090)'%3E%3Crect%20x='86'%20y='54'%20width='220'%20height='96'%20rx='48'%20fill='url(%23t1)'%20stroke='%23ffffff'%20stroke-opacity='0.10'/%3E%3Cpath%20d='M196%2054v96'%20stroke='%23ffffff'%20stroke-opacity='0.14'/%3E%3C/g%3E%3Cg%20transform='translate(292%2092)%20rotate(18%2046%2046)'%3E%3Ccircle%20cx='46'%20cy='46'%20r='36'%20fill='url(%23p1)'%20stroke='%23ffffff'%20stroke-opacity='0.10'/%3E%3Cpath%20d='M18%2046h56'%20stroke='%23ffffff'%20stroke-opacity='0.10'/%3E%3C/g%3E%3Cg%20transform='translate(296%20274)%20rotate(-10%2040%2040)'%3E%3Ccircle%20cx='40'%20cy='40'%20r='32'%20fill='url(%23p1)'%20stroke='%23ffffff'%20stroke-opacity='0.10'/%3E%3C/g%3E%3C/svg%3E");
