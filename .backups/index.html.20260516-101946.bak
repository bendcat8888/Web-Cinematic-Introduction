      --capsule-bg-strands: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='520'%20height='520'%20viewBox='0%200%20520%20520'%3E%3Cdefs%3E%3ClinearGradient%20id='sg1'%20x1='0'%20y1='0'%20x2='1'%20y2='1'%3E%3Cstop%20offset='0'%20stop-color='%233bf1ff'%20stop-opacity='0.18'/%3E%3Cstop%20offset='1'%20stop-color='%23ff3aa8'%20stop-opacity='0.14'/%3E%3C/linearGradient%3E%3ClinearGradient%20id='sg2'%20x1='1'%20y1='0'%20x2='0'%20y2='1'%3E%3Cstop%20offset='0'%20stop-color='%237a35ff'%20stop-opacity='0.16'/%3E%3Cstop%20offset='1'%20stop-color='%23ffffff'%20stop-opacity='0.06'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect%20width='520'%20height='520'%20fill='none'/%3E%3Cg%20fill='none'%20stroke-linecap='round'%3E%3Cpath%20d='M22%20168%20c90-84%20170-86%20266-10%20s180%2082%20210%2012'%20stroke='url(%23sg1)'%20stroke-width='2'%20stroke-opacity='0.35'/%3E%3Cpath%20d='M38%20364%20c98-78%20176-78%20258-8%20s168%2082%20192%2018'%20stroke='url(%23sg2)'%20stroke-width='2'%20stroke-opacity='0.30'/%3E%3Cpath%20d='M90%20252%20c44-44%20108-66%20178-52%20s124%2052%20164%2092'%20stroke='%23ffffff'%20stroke-opacity='0.12'%20stroke-width='1.4'%20/%3E%3C/g%3E%3Cg%20fill='%23ffffff'%20fill-opacity='0.10'%3E%3Ccircle%20cx='118'%20cy='140'%20r='2'/%3E%3Ccircle%20cx='286'%20cy='162'%20r='2.2'/%3E%3Ccircle%20cx='402'%20cy='146'%20r='1.8'/%3E%3Ccircle%20cx='156'%20cy='360'%20r='2.1'/%3E%3Ccircle%20cx='318'%20cy='392'%20r='2.4'/%3E%3Ccircle%20cx='430'%20cy='374'%20r='1.9'/%3E%3C/g%3E%3C/svg%3E");
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      background: radial-gradient(1200px 900px at 70% 20%, rgba(122,53,255,0.10), transparent 55%),
                  radial-gradient(900px 700px at 25% 65%, rgba(59,241,255,0.07), transparent 60%),
                  radial-gradient(ellipse 140% 60% at 30% 100%, rgba(59,241,255,0.09), transparent 55%),
                  radial-gradient(ellipse 80% 50% at 80% 90%, rgba(122,53,255,0.07), transparent 55%),
                  linear-gradient(180deg, var(--bg1), var(--bg0));
      overflow-x:hidden;
      overflow-y:hidden;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      color: var(--ink);
    }

    body.revealed{
      overflow-y:auto;
    }

    body::before{
      content:"";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: calc(var(--sunrise) * 1.25);
      background:
        radial-gradient(900px 620px at 50% 10%, rgba(255,255,255,0.26), rgba(255,255,255,0) 60%),
        radial-gradient(1200px 900px at 65% 30%, rgba(255,210,140,0.26), rgba(255,210,140,0) 62%),
        radial-gradient(900px 900px at 20% 80%, rgba(59,241,255,0.16), rgba(59,241,255,0) 65%),
        radial-gradient(700px 500px at 85% 60%, rgba(255,58,168,0.10), rgba(255,58,168,0) 60%),
        linear-gradient(180deg, rgba(255,255,255,0.00), rgba(255,255,255,0.08) 52%, rgba(255,255,255,0.18));
      background-position-y: calc(var(--sunrise) * -60px);
      background-size: 100% calc(100% + 60px);
      transition: opacity 120ms linear;
      z-index: 1;
    }

    body::after{
      content:"";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: 0;
      background: none;
      z-index: 1;
    }

    @supports (transform: rotate(1deg)) {
      body::after {
        transform: rotate(calc(var(--sunrise) * 2deg));
        transform-origin: center center;
      }
    }

    .bg-vignette{
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: var(--vignette);
      background: radial-gradient(ellipse 90% 80% at center, transparent 52%, rgba(4,3,16,0.60));
      transition: opacity 180ms linear;
      z-index: 1;
    }

    .section-bg,
    .capsule-layer{
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
    }

    .about-wireframe-layer{
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0;
      transition: opacity 220ms linear;
      mix-blend-mode: screen;
      filter: saturate(1.06) brightness(1.01);
      -webkit-mask-image: radial-gradient(860px 620px at 52% 44%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.82) 44%, rgba(0,0,0,0) 74%);
      mask-image: radial-gradient(860px 620px at 52% 44%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.82) 44%, rgba(0,0,0,0) 74%);
      transform: translate(calc(var(--parallax-x) * 0.65), calc(var(--parallax-y) * 0.55));
      will-change: opacity, transform;
    }

    html[data-active-section="about"] .about-wireframe-layer{
      opacity: clamp(0, calc(var(--sunrise) * 0.78), 0.58);
    }

    .quality-bg-layer{
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0;
      transition: opacity 220ms linear;
      mix-blend-mode: screen;
      filter: saturate(1.04) brightness(1.01);
      -webkit-mask-image: radial-gradient(980px 640px at 52% 46%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 44%, rgba(0,0,0,0) 76%);
      mask-image: radial-gradient(980px 640px at 52% 46%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 44%, rgba(0,0,0,0) 76%);
      transform: translate(calc(var(--parallax-x) * 0.55), calc(var(--parallax-y) * 0.45));
      will-change: opacity, transform;
    }

    html[data-active-section="quality"] .quality-bg-layer{
      opacity: clamp(0, calc(var(--sunrise) * 0.62), 0.46);
    }

    .quality-bg-layer svg{
      width: min(980px, 92vw);
      max-height: 64vh;
      height: auto;
      position: absolute;
      left: 52%;
      top: 46%;
      transform: translate(-50%, -50%);
      opacity: 0.62;
    }

    @media (max-width: 720px){
      .quality-bg-layer{
        -webkit-mask-image: radial-gradient(720px 520px at 50% 44%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 46%, rgba(0,0,0,0) 78%);
        mask-image: radial-gradient(720px 520px at 50% 44%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 46%, rgba(0,0,0,0) 78%);
      }

      .quality-bg-layer svg{
        width: min(640px, 96vw);
        max-height: 58vh;
        left: 50%;
        top: 44%;
        opacity: 0.56;
      }
    }

    .how-network-layer{
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0;
      transition: opacity 220ms linear;
      mix-blend-mode: screen;
      filter: saturate(1.04) brightness(1.02);
      -webkit-mask-image: radial-gradient(980px 640px at 52% 46%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 44%, rgba(0,0,0,0) 76%);
      mask-image: radial-gradient(980px 640px at 52% 46%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 44%, rgba(0,0,0,0) 76%);
      transform: translate(calc(var(--parallax-x) * 0.55), calc(var(--parallax-y) * 0.45));
      will-change: opacity, transform;
    }

    html[data-active-section="how"] .how-network-layer{
      opacity: clamp(0, calc(var(--sunrise) * 0.62), 0.44);
    }

    .how-network-layer svg{
      width: min(980px, 92vw);
      max-height: 64vh;
      height: auto;
      position: absolute;
      left: 52%;
      top: 46%;
      transform: translate(-50%, -50%);
      opacity: 0.66;
    }

    @media (max-width: 720px){
      .how-network-layer{
        -webkit-mask-image: radial-gradient(720px 520px at 50% 44%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 46%, rgba(0,0,0,0) 78%);
        mask-image: radial-gradient(720px 520px at 50% 44%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.84) 46%, rgba(0,0,0,0) 78%);
      }

      .how-network-layer svg{
        width: min(720px, 96vw);
        max-height: 58vh;
        left: 50%;
        top: 44%;
        opacity: 0.60;
      }
    }

    @media (pointer: coarse){
      .about-wireframe-layer,
      .quality-bg-layer,
      .how-network-layer{
        mix-blend-mode: normal;
        filter: none;
        -webkit-mask-image: none;
        mask-image: none;
        transform: translate3d(0,0,0);
      }

      .capsule-layer::before,
      .capsule-layer::after{
        background-position: var(--capsule-pos-x) var(--capsule-pos-y);
        will-change: opacity;
      }
    }

    .about-wireframe-layer svg{
      width: min(860px, 86vw);
      max-height: 72vh;
      height: auto;
      position: absolute;
      left: 52%;
      top: 44%;
      transform: translate(-50%, -50%);
      opacity: 0.72;
    }

    @media (max-width: 720px){
      .about-wireframe-layer{
        -webkit-mask-image: radial-gradient(680px 520px at 50% 42%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.82) 46%, rgba(0,0,0,0) 76%);
        mask-image: radial-gradient(680px 520px at 50% 42%, rgba(0,0,0,1) 0%, rgba(0,0,0,0.82) 46%, rgba(0,0,0,0) 76%);
      }

      .about-wireframe-layer svg{
        width: min(560px, 92vw);
        max-height: 66vh;
        left: 50%;
        top: 42%;
        opacity: 0.66;
      }
    }

    @media (max-width: 420px){
      .about-wireframe-layer svg{
        width: min(470px, 96vw);
        max-height: 62vh;
        top: 40%;
      }
    }

    .about-wireframe-layer .sweep{
      stroke-dasharray: 18 16;
      animation: wireSweep 2.8s linear infinite;
    }

    .about-wireframe-layer .sweep2{
      stroke-dasharray: 12 12;
      animation: wireSweep2 3.2s linear infinite;
    }

    .about-wireframe-layer .heartbeat{
      animation: beatGlow 1.4s ease-in-out infinite;
      transform-origin: 240px 194px;
      filter: drop-shadow(0 0 10px rgba(79,254,250,0.55)) drop-shadow(0 0 22px rgba(36,231,227,0.28));
      will-change: opacity, filter;
    }

    .about-wireframe-layer .brand-pulse{
      animation: brandBeatGlow 1.4s ease-in-out infinite;
      filter: drop-shadow(0 0 12px rgba(79,254,250,0.65)) drop-shadow(0 0 28px rgba(36,231,227,0.40));
      will-change: opacity, filter;
    }

    @keyframes wireSweep{
      0%{ stroke-dashoffset: 0; opacity: 0.00; }
      18%{ opacity: 0.36; }
      50%{ opacity: 0.22; }
      100%{ stroke-dashoffset: -420; opacity: 0.00; }
    }

    @keyframes wireSweep2{
      0%{ stroke-dashoffset: 0; opacity: 0.00; }
      22%{ opacity: 0.30; }
      55%{ opacity: 0.18; }
      100%{ stroke-dashoffset: -520; opacity: 0.00; }
    }

    @keyframes beatGlow{
      0%{ opacity: 0.22; filter: drop-shadow(0 0 6px rgba(79,254,250,0.35)) drop-shadow(0 0 14px rgba(36,231,227,0.18)); }
      25%{ opacity: 0.92; filter: drop-shadow(0 0 16px rgba(79,254,250,0.70)) drop-shadow(0 0 34px rgba(36,231,227,0.42)); }
      55%{ opacity: 0.34; filter: drop-shadow(0 0 8px rgba(79,254,250,0.42)) drop-shadow(0 0 18px rgba(36,231,227,0.22)); }
      100%{ opacity: 0.22; filter: drop-shadow(0 0 6px rgba(79,254,250,0.35)) drop-shadow(0 0 14px rgba(36,231,227,0.18)); }
    }

    @keyframes brandBeatGlow{
      0%{ opacity: 0.42; filter: drop-shadow(0 0 8px rgba(79,254,250,0.42)) drop-shadow(0 0 18px rgba(36,231,227,0.22)); }
      25%{ opacity: 1; filter: drop-shadow(0 0 22px rgba(79,254,250,0.82)) drop-shadow(0 0 44px rgba(36,231,227,0.52)); }
      55%{ opacity: 0.58; filter: drop-shadow(0 0 12px rgba(79,254,250,0.55)) drop-shadow(0 0 26px rgba(36,231,227,0.34)); }
      100%{ opacity: 0.42; filter: drop-shadow(0 0 8px rgba(79,254,250,0.42)) drop-shadow(0 0 18px rgba(36,231,227,0.22)); }
    }

    .section-bg::before,
    .section-bg::after{
      content: "";
      position: absolute;
      inset: 0;
      opacity: calc(1 - var(--section-bg-mix));
      background: var(--section-bg-a);
      transition: opacity 740ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: opacity;
    }

    .section-bg::after{
      opacity: var(--section-bg-mix);
      background: var(--section-bg-b);
    }

    .capsule-layer{
      opacity: var(--capsules);
      transition: opacity 180ms linear;
      -webkit-mask-image: var(--capsule-mask);
      mask-image: var(--capsule-mask);
    }

    .capsule-layer::before,
    .capsule-layer::after{
      content: "";
      position: absolute;
      inset: 0;
      opacity: calc(1 - var(--capsule-mix));
      background-image: var(--capsule-a);
      background-size: var(--capsule-size) var(--capsule-size);
      background-repeat: var(--capsule-repeat);
      background-position: calc(var(--capsule-pos-x) + var(--sunrise) * 26px + var(--parallax-x)) calc(var(--capsule-pos-y) - var(--sunrise) * 18px + var(--parallax-y));
      filter: blur(0.25px) saturate(1.10);
      will-change: opacity, background-position;
      transition: opacity 740ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .capsule-layer::after{
      opacity: var(--capsule-mix);
      background-image: var(--capsule-b);
    }

    canvas#particles{
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      opacity: var(--particles-opacity);
      transition: opacity 1200ms ease;
      z-index: 1;
    }

    body.revealed canvas#particles{
      opacity: var(--particles-opacity);
    }

    body:not(.revealed) canvas#particles{
      opacity: 0.82;
    }

    canvas#scene{
      position:fixed;
      inset:0;
      width:100%;
      height:100%;
      display:block;
      z-index: 0;
    }

    .ui{
      min-height: 100vh;
      display:grid;
      place-items:center;
      pointer-events:none;
      padding: clamp(18px, 4vw, 48px);
      position: relative;
      z-index: 2;
    }

    .card{
      width:min(980px, 100%);
      border-radius: calc(var(--r) + 8px);
      background: radial-gradient(900px 420px at 50% 0%, rgba(122,53,255,0.22), rgba(10,9,24,0.20)),
                  linear-gradient(180deg, rgba(16,14,34,0.62), rgba(10,9,24,0.46));
      border: 1px solid rgba(190,175,255,0.18);
      box-shadow: 0 26px 80px rgba(0,0,0,0.55);
      padding: clamp(22px, 4.2vw, 46px);
      backdrop-filter: blur(10px);
      transform: translateY(24px) scale(0.982);
      opacity: 0;
      filter: saturate(0.96) blur(12px);
      transition: opacity 1100ms cubic-bezier(0.16, 1, 0.3, 1), transform 1100ms cubic-bezier(0.16, 1, 0.3, 1), filter 1100ms ease;
      will-change: transform, opacity, filter;
      pointer-events:none;
      position: relative;
    }

    .card .topline,
    .card h1,
    .card .sub,
    .card .actions{
      opacity: 0;
      transform: translateY(22px);
      filter: blur(10px);
      transition: opacity 900ms cubic-bezier(0.16, 1, 0.3, 1), transform 900ms cubic-bezier(0.16, 1, 0.3, 1), filter 900ms ease;
      will-change: transform, opacity, filter;
    }

    .construction-badge{
      position: absolute;
      top: 14px;
      right: 14px;
      width: 66px;
      height: 48px;
      border-radius: 12px;
      border: 1px solid rgba(190,175,255,0.18);
      background: rgba(10,9,24,0.42);
      box-shadow: 0 16px 48px rgba(0,0,0,0.36);
      display: grid;
      place-items: center;
      color: rgba(255,255,255,0.92);
      pointer-events: none;
      overflow: hidden;
    }

    .construction-badge img{
      width: 100%;
      height: 100%;
      display: block;
      object-fit: contain;
    }

    body.revealed .card{
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: saturate(1) blur(0);
      pointer-events:auto;
    }

    body.revealed .card .topline{
      opacity: 0.98;
      transform: translateY(0);
      filter: blur(0);
      transition-delay: 80ms;
    }

    body.revealed .card h1{
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
      transition-delay: 150ms;
    }

    body.revealed .card .sub{
      opacity: 0.86;
      transform: translateY(0);
      filter: blur(0);
      transition-delay: 220ms;
    }

    body.revealed .card .actions{
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
      transition-delay: 290ms;
    }

    .topline{
      display:flex;
      align-items:center;
      gap:18px;
      margin-bottom: 14px;
    }

    .mark{
      width: clamp(180px, 17vw, 230px);
      aspect-ratio: 2.87 / 1;
      height: auto;
      flex: 0 0 auto;
      border-radius: 999px;
      background: #ffffff;
      border: 1px solid rgba(255,255,255,0.72);
      box-shadow: 0 16px 46px rgba(0,0,0,0.28), 0 14px 46px rgba(122,53,255,0.16), inset 0 0 0 1px rgba(122,53,255,0.08);
      display:grid;
      place-items:center;
      padding: clamp(5px, 0.55vw, 8px) clamp(9px, 0.9vw, 12px);
      overflow:hidden;
    }

    .mark img{
      display:block;
      width: 82%;
      height: 82%;
      object-fit: contain;
      object-position: center;
      filter: none;
      opacity: 1;
    }

    .kicker{
      font-size: clamp(12px, 1.05vw, 14px);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(233,232,255,0.78);
      line-height: 1;
    }

    h1{
      margin: 0;
      font-size: clamp(30px, 3.6vw, 54px);
      line-height: 1.05;
      letter-spacing: -0.02em;
      text-shadow: 0 26px 80px rgba(0,0,0,0.62);
    }

    .sub{
      margin-top: 10px;
      font-size: clamp(14px, 1.55vw, 18px);
      line-height: 1.55;
      color: rgba(233,232,255,0.78);
      max-width: 62ch;
    }

    .actions{
      margin-top: 22px;
      display:flex;
      gap: 12px;
      align-items:center;
      flex-wrap: wrap;
    }

    .btn{
      pointer-events:auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      appearance:none;
      border: 0;
      border-radius: 999px;
      padding: 13px 18px;
      color: rgba(255,255,255,0.94);
      background: var(--btn);
      box-shadow: 0 14px 40px rgba(122,53,255,0.24), 0 14px 28px rgba(0,0,0,0.40);
      font-weight: 650;
      letter-spacing: 0.01em;
      cursor:pointer;
      transform: translateY(0);
      transition: transform 180ms ease, box-shadow 220ms ease, filter 220ms ease, background 220ms ease;
    }
    .btn:hover{
      transform: translateY(-1px);
      filter: brightness(1.06) saturate(1.05);
      background: var(--btn2);
      box-shadow: 0 18px 56px rgba(122,53,255,0.32), 0 18px 34px rgba(0,0,0,0.42);
    }
    .btn:active{ transform: translateY(0); }

    .pill{
      pointer-events:none;
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding: 10px 12px;
      border-radius: 999px;
      border: 1px solid rgba(190,175,255,0.16);
      background: linear-gradient(180deg, rgba(16,14,34,0.48), rgba(10,9,24,0.32));
      color: rgba(233,232,255,0.74);
      font-size: 13px;
      letter-spacing: 0.01em;
    }
    .dot{
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.95), rgba(255,255,255,0.25) 35%, rgba(255,255,255,0) 70%),
                  radial-gradient(circle at 50% 50%, rgba(59,241,255,0.75), rgba(59,241,255,0) 68%),
                  radial-gradient(circle at 50% 50%, rgba(182,77,255,0.85), rgba(182,77,255,0) 70%);
      box-shadow: 0 0 18px rgba(59,241,255,0.35), 0 0 20px rgba(122,53,255,0.28);
    }

    .maintenance-pop{
      position:fixed;
      inset:0;
      display:grid;
      place-items:center;
      padding: 20px;
      background: rgba(7, 7, 18, 0.58);
      backdrop-filter: blur(7px);
      opacity:0;
      visibility:hidden;
      pointer-events:none;
      transition: opacity 220ms ease, visibility 220ms ease;
      z-index: 5;
    }

    .maintenance-pop.is-open{
      opacity:1;
      visibility:visible;
      pointer-events:auto;
    }

    .maintenance-panel{
      width:min(360px, 100%);
      border-radius: 18px;
      border: 1px solid rgba(190,175,255,0.24);
      background: linear-gradient(180deg, rgba(30,24,64,0.96), rgba(12,10,28,0.94));
      box-shadow: 0 28px 90px rgba(0,0,0,0.58), 0 18px 52px rgba(122,53,255,0.20);
      color: var(--ink);
      padding: 22px;
      transform: translateY(10px) scale(0.98);
      transition: transform 220ms ease;
    }

    .maintenance-pop.is-open .maintenance-panel{
      transform: translateY(0) scale(1);
    }

    .maintenance-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
    }

    .maintenance-title{
      margin:0;
      font-size: 18px;
      line-height:1.2;
      letter-spacing:0;
    }

    .maintenance-close{
      appearance:none;
      border:1px solid rgba(190,175,255,0.18);
      border-radius:999px;
      width:34px;
      height:34px;
      display:grid;
      place-items:center;
      background: rgba(255,255,255,0.06);
      color: rgba(233,232,255,0.82);
      cursor:pointer;
      font-size:22px;
      line-height:1;
    }

    .maintenance-close:hover{
      background: rgba(255,255,255,0.10);
      color: rgba(255,255,255,0.96);
    }

    .maintenance-copy{
      margin: 12px 0 0;
      color: rgba(233,232,255,0.76);
      font-size: 14px;
      line-height:1.5;
    }

    .maintenance-media{
      margin-top: 14px;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid rgba(190,175,255,0.16);
      background: rgba(0,0,0,0.20);
    }

    .maintenance-media img{
      width: 100%;
      height: auto;
      display: block;
    }

    .products-pop{
      position:fixed;
      inset:0;
      display:grid;
      place-items:center;
      padding: 18px;
      background: rgba(7, 7, 18, 0.62);
      backdrop-filter: blur(8px);
      opacity:0;
      visibility:hidden;
      pointer-events:none;
      transition: opacity 220ms ease, visibility 220ms ease;
      z-index: 6;
    }

    .products-pop.is-open{
      opacity:1;
      visibility:visible;
      pointer-events:auto;
    }

    .products-panel{
      width: min(980px, 100%);
      max-height: min(82vh, 720px);
      border-radius: 18px;
      border: 1px solid rgba(190,175,255,0.22);
      background: linear-gradient(180deg, rgba(22,18,44,0.96), rgba(12,10,28,0.94));
      box-shadow: 0 28px 90px rgba(0,0,0,0.60), 0 18px 52px rgba(59,241,255,0.10);
      color: var(--ink);
      padding: 18px;
      display:flex;
      flex-direction:column;
      transform: translateY(10px) scale(0.985);
      transition: transform 220ms ease;
    }

    .products-pop.is-open .products-panel{
      transform: translateY(0) scale(1);
    }

    .products-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(190,175,255,0.12);
    }

    .products-title{
      margin:0;
      font-size: 18px;
      line-height:1.2;
    }

    .products-close{
      appearance:none;
      border:1px solid rgba(190,175,255,0.18);
      border-radius:999px;
      width:34px;
      height:34px;
      display:grid;
      place-items:center;
      background: rgba(255,255,255,0.06);
      color: rgba(233,232,255,0.82);
      cursor:pointer;
      font-size:22px;
      line-height:1;
    }

    .products-close:hover{
      background: rgba(255,255,255,0.10);
      color: rgba(255,255,255,0.96);
    }

    .products-tools{
      display:grid;
      grid-template-columns: 220px 1fr;
      gap: 12px;
      padding-top: 12px;
      padding-bottom: 12px;
    }

    .products-field{
      display:flex;
      flex-direction:column;
      gap: 8px;
      min-width:0;
    }

    .products-label{
      font-size: 12px;
      color: rgba(233,232,255,0.62);
      letter-spacing: 0.02em;
    }

    .products-select,
    .products-search{
      width: 100%;
      border-radius: 12px;
      border: 1px solid rgba(190,175,255,0.16);
      background: rgba(8,8,18,0.42);
      color: rgba(233,232,255,0.88);
      padding: 10px 12px;
      outline: none;
    }

    .products-select:focus,
    .products-search:focus{
      border-color: rgba(59,241,255,0.35);
      box-shadow: 0 0 0 3px rgba(59,241,255,0.10);
    }

    .products-body{
      display:grid;
      grid-template-columns: 360px 1fr;
      gap: 14px;
      overflow:hidden;
      min-height: 0;
      flex: 1;
    }

    .products-list{
      overflow:auto;
      border-radius: 14px;
      border: 1px solid rgba(190,175,255,0.14);
      background: rgba(0,0,0,0.18);
      padding: 10px;
      display:flex;
      flex-direction:column;
      gap: 8px;
      min-height: 0;
    }

    .products-item{
      appearance:none;
      text-align:left;
      width:100%;
      border-radius: 14px;
      border: 1px solid rgba(190,175,255,0.12);
      background: linear-gradient(180deg, rgba(16,14,34,0.50), rgba(10,9,24,0.30));
      color: rgba(233,232,255,0.88);
      padding: 12px 12px;
      cursor:pointer;
      transition: transform 160ms ease, border-color 180ms ease, background 180ms ease;
    }

    .products-item:hover{
      transform: translateY(-1px);
      border-color: rgba(59,241,255,0.22);
    }

    .products-item.is-active{
      border-color: rgba(59,241,255,0.34);
      background: linear-gradient(180deg, rgba(24,22,54,0.62), rgba(10,9,24,0.32));
    }

    .products-item-title{
      font-weight: 680;
      font-size: 14px;
      line-height: 1.25;
    }

    .products-item-meta{
      margin-top: 6px;
      color: rgba(233,232,255,0.62);
      font-size: 12.5px;
      line-height: 1.45;
    }

    .products-detail{
      overflow:auto;
      border-radius: 14px;
      border: 1px solid rgba(190,175,255,0.14);
      background: rgba(0,0,0,0.16);
      padding: 14px;
      min-height: 0;
    }

    .products-detail-inner{
      display:flex;
      flex-direction:column;
      gap: 12px;
    }

    .products-hero{
      width: 100%;
      height: auto;
      border-radius: 14px;
      border: 1px solid rgba(190,175,255,0.14);
      background: rgba(0,0,0,0.22);
      display:block;
    }

    .products-name{
      font-size: 18px;
      font-weight: 760;
      line-height: 1.18;
    }

    .products-kv{
      margin: 0;
      display:flex;
      flex-direction:column;
      gap: 8px;
    }

    .products-kv-row{
      display:grid;
      grid-template-columns: 140px 1fr;
      gap: 10px;
      padding: 10px 10px;
      border-radius: 12px;
      border: 1px solid rgba(190,175,255,0.12);
      background: rgba(255,255,255,0.04);
    }

    .products-kv dt{
      color: rgba(233,232,255,0.62);
      font-size: 12px;
      letter-spacing: 0.02em;
    }

    .products-kv dd{
      margin:0;
      color: rgba(233,232,255,0.88);
      font-size: 13px;
      line-height: 1.45;
    }

    .products-download{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding: 12px 14px;
      border-radius: 999px;
      border: 1px solid rgba(59,241,255,0.24);
      background: rgba(59,241,255,0.08);
      color: rgba(233,232,255,0.92);
      text-decoration:none;
      font-weight: 650;
      width: fit-content;
    }

    .products-download:hover{
      background: rgba(59,241,255,0.12);
      border-color: rgba(59,241,255,0.34);
    }

    .products-empty{
      padding: 14px 10px;
      color: rgba(233,232,255,0.62);
      font-size: 13px;
      line-height: 1.45;
    }

    @media (max-width: 860px){
      .products-tools{ grid-template-columns: 1fr; }
      .products-body{ grid-template-columns: 1fr; }
      .products-panel{ max-height: min(86vh, 820px); }
      .products-kv-row{ grid-template-columns: 1fr; gap: 6px; }
    }

    .hint{
      position:fixed;
      left: 16px;
      bottom: 14px;
      font-size: 12px;
      color: rgba(233,232,255,0.50);
      letter-spacing: 0.02em;
      user-select:none;
      opacity: 0.9;
      text-shadow: 0 16px 60px rgba(0,0,0,0.85);
      transition: opacity 700ms ease;
      z-index: 3;
    }
    body.revealed .hint{ opacity: 0; }

    .a11y-skip{
      position:fixed;
      top: 12px;
      right: 12px;
      pointer-events:auto;
      background: rgba(10,9,24,0.35);
      border: 1px solid rgba(190,175,255,0.18);
      color: rgba(233,232,255,0.80);
      padding: 10px 12px;
      border-radius: 999px;
      font-size: 12px;
      cursor:pointer;
      opacity: 0.0;
      transform: translateY(-8px);
      transition: opacity 350ms ease, transform 350ms ease, background 220ms ease;
      z-index: 3;
    }
    .a11y-skip:focus-visible{
      outline: 2px solid rgba(59,241,255,0.55);
      outline-offset: 2px;
      opacity: 1.0;
      transform: translateY(0);
    }

    main{
      position: relative;
      z-index: 2;
    }

    .reveal-on-scroll{
      opacity: 0;
      transform: translateY(26px);
      filter: blur(12px);
      transition: opacity 900ms cubic-bezier(0.16, 1, 0.3, 1), transform 900ms cubic-bezier(0.16, 1, 0.3, 1), filter 900ms ease;
      will-change: transform, opacity, filter;
    }

    body.revealed .reveal-on-scroll.is-visible{
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }

    .content-section{
      width: min(980px, 100%);
      margin: 0 auto;
      padding: clamp(58px, 9vw, 110px) clamp(18px, 4vw, 48px);
    }

    .content-section .lead{
      margin: 0 0 22px;
      color: rgba(233,232,255,0.78);
      font-size: clamp(15px, 1.75vw, 20px);
      line-height: 1.55;
      max-width: 70ch;
    }

    .story-grid{
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      margin-top: 18px;
    }

    .story-card{
      border-radius: 16px;
      border: 1px solid rgba(190,175,255,0.16);
      background: linear-gradient(180deg, rgba(16,14,34,0.52), rgba(10,9,24,0.32));
      box-shadow: 0 18px 48px rgba(0,0,0,0.32);
      padding: 16px 16px 14px;
      backdrop-filter: blur(10px);
    }

    .story-kicker{
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(59,241,255,0.82);
    }

    .story-title{
      margin: 10px 0 8px;
      font-size: clamp(18px, 2.3vw, 26px);
      line-height: 1.1;
      color: rgba(255,255,255,0.95);
      letter-spacing: -0.01em;
    }

    .story-card p{
      margin: 0;
      color: rgba(233,232,255,0.72);
      font-size: clamp(13px, 1.4vw, 16px);
      line-height: 1.6;
      max-width: none;
    }

    .deep-copy{
      margin-top: 22px;
      border-radius: 16px;
      border: 1px solid rgba(190,175,255,0.16);
      background: rgba(10,9,24,0.28);
      overflow: hidden;
    }

    .deep-copy summary{
      list-style: none;
      cursor: pointer;
      padding: 14px 16px;
      color: rgba(233,232,255,0.86);
      font-weight: 650;
      letter-spacing: -0.01em;
      background: linear-gradient(90deg, rgba(122,53,255,0.14), rgba(59,241,255,0.08), rgba(255,58,168,0.08));
      user-select: none;
    }

    .deep-copy summary::-webkit-details-marker{ display: none; }

    .deep-copy[open] summary{
      border-bottom: 1px solid rgba(190,175,255,0.14);
    }

    .deep-copy-body{
      padding: 16px;
    }

    .deep-copy-body h3{
      margin-top: 24px;
    }

    .values-list{
      margin: 14px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      max-width: 72ch;
    }

    .values-list li{
      border-radius: 14px;
      border: 1px solid rgba(190,175,255,0.14);
      background: rgba(10,9,24,0.20);
      padding: 10px 12px;
      text-align: center;
      color: rgba(233,232,255,0.86);
      font-weight: 650;
      letter-spacing: -0.01em;
    }

    .products-section .pl-grid{
      margin-top: 18px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .products-section .pl-card{
      margin: 0;
      border-radius: 16px;
      border: 1px solid rgba(190,175,255,0.16);
      background: linear-gradient(180deg, rgba(16,14,34,0.52), rgba(10,9,24,0.32));
      box-shadow: 0 18px 48px rgba(0,0,0,0.32);
      overflow: hidden;
      transform: translateY(0);
      transition: transform 520ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 520ms cubic-bezier(0.16, 1, 0.3, 1);
      touch-action: pan-y;
      -webkit-tap-highlight-color: transparent;
    }

    .products-section .pl-card.is-active{
      transform: translateY(-6px);
      box-shadow: 0 26px 72px rgba(0,0,0,0.38);
    }

    .products-section .pl-card.is-active img{
      filter: saturate(1.08) contrast(1.06) brightness(1.02);
    }

    .products-section .pl-card img{
      width: 100%;
      height: auto;
      display: block;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      filter: saturate(1.02) contrast(1.03);
      transform: translate3d(0,0,0) scale(1);
      transition: transform 140ms ease-out, filter 520ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
      pointer-events: none;
      user-select: none;
      -webkit-user-select: none;
      -webkit-touch-callout: none;
      -webkit-user-drag: none;
    }

    .products-section .pl-card figcaption{
      padding: 12px 14px;
      color: rgba(233,232,255,0.86);
      font-weight: 650;
      letter-spacing: -0.01em;
      background: linear-gradient(90deg, rgba(122,53,255,0.14), rgba(59,241,255,0.08), rgba(255,58,168,0.08));
      border-top: 1px solid rgba(190,175,255,0.14);
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .products-section .pl-meta{
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(233,232,255,0.72);
    }

    .tier-grid{
      margin-top: 18px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .tier-card{
      border-radius: 18px;
      border: 1px solid rgba(190,175,255,0.16);
      background: linear-gradient(180deg, rgba(16,14,34,0.52), rgba(10,9,24,0.32));
      box-shadow: 0 18px 48px rgba(0,0,0,0.32);
      padding: 18px 18px 16px;
    }

    .tier-title{
      margin: 10px 0 10px;
      font-size: clamp(18px, 2.2vw, 26px);
      line-height: 1.1;
      color: rgba(255,255,255,0.95);
      letter-spacing: -0.01em;
    }

    .tier-card ul{
      margin: 12px 0 0;
      padding: 0 0 0 18px;
      color: rgba(233,232,255,0.74);
      font-size: clamp(13px, 1.4vw, 16px);
      line-height: 1.6;
    }

    .tier-card li + li{ margin-top: 8px; }

    .contact-list{
      margin: 18px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 10px;
      max-width: 72ch;
      color: rgba(233,232,255,0.74);
      font-size: clamp(14px, 1.6vw, 18px);
      line-height: 1.7;
    }

    .contact-list a{
      color: rgba(233,232,255,0.84);
      text-decoration: none;
      border-bottom: 1px solid rgba(190,175,255,0.18);
    }

    .contact-list a:hover{
      color: rgba(255,255,255,0.92);
      border-color: rgba(59,241,255,0.55);
    }

    .contact-label{
      display: inline-block;
      min-width: 76px;
      color: rgba(59,241,255,0.86);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-right: 10px;
    }

    .contact-sep{
      display: inline-block;
      margin: 0 10px;
      color: rgba(233,232,255,0.52);
    }

    .contact-hours,
    .contact-social{
      margin-top: 16px;
      color: rgba(233,232,255,0.72);
      max-width: 72ch;
    }

    .contact-social a{
      color: rgba(233,232,255,0.84);
      text-decoration: none;
      border-bottom: 1px solid rgba(190,175,255,0.18);
    }

    .contact-social a:hover{
      color: rgba(255,255,255,0.92);
      border-color: rgba(59,241,255,0.55);
    }

    @media (hover:hover) and (pointer:fine){
      .products-section .pl-card:hover{
        transform: translateY(-6px);
        box-shadow: 0 26px 72px rgba(0,0,0,0.38);
      }
      .products-section .pl-card:hover img{
        filter: saturate(1.08) contrast(1.06) brightness(1.02);
      }
    }

    .maintenance-strip{
      padding-top: clamp(14px, 3vw, 28px);
    }

    .maintenance-banner{
      width: min(735px, 100%);
      height: auto;
      display: block;
      margin: 0 auto;
      border-radius: 16px;
      border: 1px solid rgba(190,175,255,0.14);
      background: rgba(10,9,24,0.26);
      box-shadow: 0 18px 58px rgba(0,0,0,0.28);
    }

    @media (max-width: 920px){
      .products-section .pl-grid{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .values-list{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .tier-grid{ grid-template-columns: 1fr; }
    }

    @media (max-width: 520px){
      .products-section .pl-grid{ grid-template-columns: 1fr; }
      .products-section .pl-card img{ aspect-ratio: 16 / 10; }
    }

    @media (max-width: 720px){
      .story-grid{ grid-template-columns: 1fr; }
    }

    .content-section h2{
      margin: 0 0 16px;
      font-size: clamp(22px, 3.2vw, 38px);
      line-height: 1.15;
      color: rgba(59,241,255,0.92);
      letter-spacing: -0.01em;
    }

    .content-section h3{
      margin: 34px 0 12px;
      font-size: clamp(16px, 2.1vw, 22px);
      line-height: 1.2;
      color: rgba(233,232,255,0.92);
    }

    .content-section p{
      margin: 0;
      color: rgba(233,232,255,0.74);
      font-size: clamp(14px, 1.6vw, 18px);
      line-height: 1.7;
      max-width: 72ch;
    }

    .content-section p + p{
      margin-top: 14px;
    }

    footer{
      border-top: 1px solid rgba(190,175,255,0.14);
      padding: 32px 18px;
      text-align: center;
      color: rgba(233,232,255,0.60);
      font-size: 13px;
    }

    .footer-sitemap{
      margin: 0 auto 14px;
      width: min(980px, 100%);
      display: flex;
      gap: 12px 18px;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
    }

    .footer-sitemap a{
      color: rgba(233,232,255,0.72);
      text-decoration: none;
      border-bottom: 1px solid rgba(190,175,255,0.18);
      padding: 4px 2px;
      transition: color 200ms ease, border-color 200ms ease;
    }

    .footer-sitemap a:hover{
      color: rgba(255,255,255,0.92);
      border-color: rgba(59,241,255,0.55);
    }

    .footer-meta{
      display: grid;
      gap: 6px;
      justify-items: center;
    }

    @media (max-width: 560px){
      .topline{ align-items:flex-start; flex-direction:column; margin-bottom: 10px; }
      .mark{ width: min(100%, 205px); }
      .actions{ margin-top: 18px; }
    }

    @media (prefers-reduced-motion: reduce){
      .card,
      .card .topline,
      .card h1,
      .card .sub,
      .card .actions{ transition: none; transform: none; filter: none; }
      .reveal-on-scroll{ transition: none; transform: none; filter: none; opacity: 1; }
      .btn{ transition: none; }
      .hint{ transition: none; }
      .maintenance-pop,
      .maintenance-panel{ transition: none; }
    }
  </style>
</head>
<body>
  <canvas id="scene" aria-hidden="true"></canvas>
  <div class="section-bg" aria-hidden="true"></div>
  <div class="capsule-layer" aria-hidden="true"></div>
  <div class="about-wireframe-layer" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="1024" height="1024" viewBox="0 0 1024 1024" role="img" aria-label="Futuristic wireframe capsules with glowing particles">
      <defs>
        <radialGradient id="bg" cx="50%" cy="45%" r="72%">
          <stop offset="0%" stop-color="#104e52"/>
          <stop offset="33%" stop-color="#07343c"/>
          <stop offset="70%" stop-color="#031d27"/>
          <stop offset="100%" stop-color="#01131b"/>
        </radialGradient>
        <radialGradient id="aura" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#4ffefa" stop-opacity=".35"/>
          <stop offset="45%" stop-color="#23e7e3" stop-opacity=".12"/>
          <stop offset="100%" stop-color="#23e7e3" stop-opacity="0"/>
        </radialGradient>
        <linearGradient id="cyanStroke" x1="0%" x2="100%" y1="0%" y2="100%">
          <stop offset="0%" stop-color="#7fffff"/>
          <stop offset="48%" stop-color="#23eee8"/>
          <stop offset="100%" stop-color="#09bbb7"/>
        </linearGradient>
        <linearGradient id="capsuleShade" x1="0%" x2="100%" y1="0%" y2="100%">
          <stop offset="0%" stop-color="#0df4eb" stop-opacity=".24"/>
          <stop offset="45%" stop-color="#0bd7d3" stop-opacity=".08"/>
          <stop offset="100%" stop-color="#001b23" stop-opacity=".22"/>
        </linearGradient>
        <radialGradient id="capFill" cx="38%" cy="30%" r="65%">
          <stop offset="0%" stop-color="#1af5ee" stop-opacity="0.10"/>
          <stop offset="50%" stop-color="#0accc8" stop-opacity="0.06"/>
          <stop offset="100%" stop-color="#002830" stop-opacity="0.50"/>
        </radialGradient>
        <linearGradient id="edgeHL" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#7ffffe" stop-opacity="0.90"/>
          <stop offset="100%" stop-color="#00aaaa" stop-opacity="0.30"/>
        </linearGradient>
        <radialGradient id="pill3d" cx="30%" cy="30%" r="75%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity=".30"/>
          <stop offset="40%" stop-color="#7fffff" stop-opacity=".20"/>
          <stop offset="100%" stop-color="#09bbb7" stop-opacity=".12"/>
        </radialGradient>
        <clipPath id="brandPillClip">
          <circle cx="798" cy="193" r="19"/>
        </clipPath>
        <filter id="glow" x="-80%" y="-80%" width="260%" height="260%">
          <feGaussianBlur stdDeviation="4" result="blur"/>
          <feColorMatrix in="blur" type="matrix" values="0 0 0 0 .03 0 0 0 0 1 0 0 0 0 .95 0 0 0 .8 0" result="cyanBlur"/>
          <feMerge>
            <feMergeNode in="cyanBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <filter id="softGlow" x="-120%" y="-120%" width="340%" height="340%">
          <feGaussianBlur stdDeviation="15" result="blur"/>
          <feColorMatrix in="blur" type="matrix" values="0 0 0 0 .05 0 0 0 0 1 0 0 0 0 .95 0 0 0 .55 0"/>
          <feMerge>
            <feMergeNode/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <filter id="heavyGlow" x="-160%" y="-160%" width="420%" height="420%">
          <feGaussianBlur stdDeviation="10" result="blur"/>
          <feColorMatrix in="blur" type="matrix" values="0 0 0 0 .03 0 0 0 0 1 0 0 0 0 .94 0 0 0 .95 0"/>
          <feMerge>
            <feMergeNode/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <pattern id="microText" width="48" height="42" patternUnits="userSpaceOnUse">
          <text x="0" y="9" fill="#58fbf5" opacity=".58" font-family="Consolas, monospace" font-size="6">010110</text>
          <text x="5" y="20" fill="#58fbf5" opacity=".45" font-family="Consolas, monospace" font-size="5">1010 001</text>
          <text x="1" y="31" fill="#58fbf5" opacity=".52" font-family="Consolas, monospace" font-size="6">DATA</text>
          <path d="M1 36 H39 M5 39 H30" stroke="#58fbf5" stroke-width=".8" opacity=".45"/>
        </pattern>
        <g id="sphereGrid">
          <circle r="36" fill="#0fe7e0" opacity=".09"/>
          <circle r="36" fill="none" stroke="#61fffb" stroke-width="1.4"/>
          <ellipse rx="36" ry="10" fill="none" stroke="#62fff9" stroke-width=".8" opacity=".8"/>
          <ellipse rx="36" ry="18" fill="none" stroke="#62fff9" stroke-width=".8" opacity=".72"/>
          <ellipse rx="36" ry="27" fill="none" stroke="#62fff9" stroke-width=".8" opacity=".55"/>
          <ellipse rx="13" ry="36" fill="none" stroke="#62fff9" stroke-width=".8" opacity=".8"/>
          <ellipse rx="24" ry="36" fill="none" stroke="#62fff9" stroke-width=".8" opacity=".63"/>
          <path d="M-35 -9 C-14 -15 14 -15 35 -9 M-35 9 C-13 16 13 16 35 9" fill="none" stroke="#62fff9" stroke-width=".8" opacity=".65"/>
          <path d="M-29 -22 C-12 -27 12 -27 29 -22 M-29 22 C-12 27 12 27 29 22" fill="none" stroke="#62fff9" stroke-width=".75" opacity=".45"/>
          <path d="M0 -36 V36 M-36 0 H36" stroke="#62fff9" stroke-width=".65" opacity=".55"/>
        </g>
      </defs>

      <circle cx="512" cy="442" r="395" fill="url(#aura)" opacity=".55"/>
      <ellipse cx="512" cy="868" rx="187" ry="35" fill="#28fff5" opacity=".15" filter="url(#softGlow)"/>

      <g fill="none" stroke="#24ede8" stroke-linecap="round" opacity=".22">
        <circle cx="512" cy="508" r="92" stroke-width="5" stroke-dasharray="85 35"/>
        <circle cx="512" cy="508" r="130" stroke-width="4" stroke-dasharray="92 44 22 34"/>
        <circle cx="512" cy="508" r="168" stroke-width="4" stroke-dasharray="80 54"/>
        <circle cx="512" cy="508" r="197" stroke-width="1.5" stroke-dasharray="210 70"/>
      </g>

      <g id="callouts" fill="none" stroke="#67fff8" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" opacity=".86" filter="url(#glow)">
        <g class="heartbeat">
          <path d="M214 196 H268 M281 194 H318 L355 231 V297"/>
          <circle cx="281" cy="194" r="3.5"/>
          <circle cx="355" cy="297" r="3.5"/>
          <path d="M218 196 C212 180 219 171 230 171 C238 171 241 176 242 182 C245 174 250 171 256 171 C267 171 272 182 263 196 L242 217 L224 199"/>
          <path d="M226 197 H235 L241 181 L247 207 L253 196 H266"/>
        </g>
        <g>
          <path d="M528 435 V173 L565 137 H615"/>
          <circle cx="528" cy="435" r="3"/>
          <circle cx="615" cy="137" r="3.4"/>
        </g>
        <g transform="translate(655 137)">
          <circle r="8.5"/>
          <circle cx="13" cy="-23" r="5"/>
          <circle cx="-21" cy="16" r="6.5"/>
          <circle cx="23" cy="8" r="4"/>
          <circle cx="-21" cy="-19" r="3.5"/>
          <circle cx="7" cy="25" r="4"/>
          <path d="M7 -7 L13 -23 M-7 6 L-21 16 M8 3 L23 8 M-6 -6 L-21 -19 M2 9 L7 25"/>
        </g>
        <g>
          <path d="M676 297 V231 L713 194 H751"/>
          <circle cx="676" cy="297" r="3.5"/>
          <circle cx="751" cy="194" r="3.4"/>
          <circle cx="798" cy="193" r="23" fill="url(#pill3d)" stroke="#67fff8" stroke-width="1.6"/>
          <image class="brand-pulse" href="assets/ifavicon.png" xlink:href="assets/ifavicon.png" x="779" y="174" width="38" height="38" clip-path="url(#brandPillClip)" preserveAspectRatio="xMidYMid slice"/>
          <path d="M784 193 H812" stroke="#67fff8" stroke-opacity=".38"/>
          <path d="M786 186 C792 178 804 178 810 186" stroke="#67fff8" stroke-opacity=".26"/>
        </g>
      </g>

      <g id="capsules" filter="url(#heavyGlow)" transform="translate(512 560) scale(1.28) translate(-340 -340)">
        <ellipse cx="340" cy="340" rx="260" ry="160" fill="url(#aura)" opacity=".38"/>
        <ellipse cx="340" cy="590" rx="155" ry="18" fill="#00ffee" fill-opacity="0.06"/>

        <g id="left-capsule" transform="translate(340,280) rotate(-10)">
          <path d="M0,-70 L-220,-70 Q-295,-70 -295,0 Q-295,70 -220,70 L0,70 Z" fill="url(#capFill)" stroke="url(#cyanStroke)" stroke-width="2.1" stroke-opacity="0.78" stroke-linejoin="round"/>
          <path d="M0,-70 L-220,-70 Q-295,-70 -295,0 Q-295,70 -220,70 L0,70 Z" fill="none" stroke="#bffefd" stroke-opacity="0.12" stroke-width="5" stroke-linejoin="round"/>
          <line x1="-295" y1="-35" x2="0" y2="-35" stroke="#2af5ee" stroke-width="0.55" stroke-opacity="0.52"/>
          <line x1="-295" y1="0" x2="0" y2="0" stroke="#2af5ee" stroke-width="0.55" stroke-opacity="0.52"/>
          <line x1="-295" y1="35" x2="0" y2="35" stroke="#2af5ee" stroke-width="0.55" stroke-opacity="0.52"/>
          <line x1="-240" y1="-70" x2="-240" y2="70" stroke="#2af5ee" stroke-width="0.55" stroke-opacity="0.45"/>
          <line x1="-180" y1="-70" x2="-180" y2="70" stroke="#2af5ee" stroke-width="0.55" stroke-opacity="0.45"/>
          <line x1="-120" y1="-70" x2="-120" y2="70" stroke="#2af5ee" stroke-width="0.55" stroke-opacity="0.45"/>
          <line x1="-60" y1="-70" x2="-60" y2="70" stroke="#2af5ee" stroke-width="0.55" stroke-opacity="0.45"/>
          <path d="M-220,-52 Q-272,-52 -272,0 Q-272,52 -220,52" fill="none" stroke="#2af5ee" stroke-width="0.6" stroke-opacity="0.5"/>
          <path d="M-220,-35 Q-255,-35 -255,0 Q-255,35 -220,35" fill="none" stroke="#2af5ee" stroke-width="0.5" stroke-opacity="0.4"/>
          <path d="M-220,-17 Q-237,-17 -237,0 Q-237,17 -220,17" fill="none" stroke="#2af5ee" stroke-width="0.5" stroke-opacity="0.35"/>
          <path d="M-220,-70 L0,-70" stroke="url(#edgeHL)" stroke-width="2.1" stroke-opacity="0.78"/>
