      --capsule-bg-tablets-dense: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='520'%20height='520'%20viewBox='0%200%20520%20520'%3E%3Cdefs%3E%3ClinearGradient%20id='d1'%20x1='0'%20y1='0'%20x2='1'%20y2='1'%3E%3Cstop%20offset='0'%20stop-color='%23ffffff'%20stop-opacity='0.20'/%3E%3Cstop%20offset='0.6'%20stop-color='%233bf1ff'%20stop-opacity='0.16'/%3E%3Cstop%20offset='1'%20stop-color='%23ff3aa8'%20stop-opacity='0.14'/%3E%3C/linearGradient%3E%3CradialGradient%20id='d2'%20cx='28%25'%20cy='30%25'%20r='78%25'%3E%3Cstop%20offset='0'%20stop-color='%23ffffff'%20stop-opacity='0.22'/%3E%3Cstop%20offset='1'%20stop-color='%237a35ff'%20stop-opacity='0.14'/%3E%3C/radialGradient%3E%3C/defs%3E%3Crect%20width='520'%20height='520'%20fill='none'/%3E%3Cg%20fill='none'%20stroke='%23ffffff'%20stroke-opacity='0.06'%3E%3Cpath%20d='M44%20162h190m54%200h188'%20/%3E%3Cpath%20d='M66%20370h160m86%200h164'%20/%3E%3C/g%3E%3Cg%20transform='translate(38%2098)%20rotate(-20%20210%20110)'%3E%3Crect%20x='110'%20y='78'%20width='260'%20height='108'%20rx='54'%20fill='url(%23d1)'%20stroke='%23ffffff'%20stroke-opacity='0.10'/%3E%3Cpath%20d='M240%2078v108'%20stroke='%23ffffff'%20stroke-opacity='0.10'/%3E%3C/g%3E%3Cg%20transform='translate(48%20292)%20rotate(14%20210%2090)'%3E%3Crect%20x='94'%20y='46'%20width='280'%20height='116'%20rx='58'%20fill='url(%23d1)'%20stroke='%23ffffff'%20stroke-opacity='0.09'/%3E%3Cpath%20d='M234%2046v116'%20stroke='%23ffffff'%20stroke-opacity='0.10'/%3E%3C/g%3E%3Cg%20transform='translate(340%20152)%20rotate(12%2058%2058)'%3E%3Ccircle%20cx='58'%20cy='58'%20r='46'%20fill='url(%23d2)'%20stroke='%23ffffff'%20stroke-opacity='0.08'/%3E%3Cpath%20d='M22%2058h72'%20stroke='%23ffffff'%20stroke-opacity='0.08'/%3E%3C/g%3E%3Cg%20transform='translate(318%20366)%20rotate(-10%2050%2050)'%3E%3Ccircle%20cx='50'%20cy='50'%20r='40'%20fill='url(%23d2)'%20stroke='%23ffffff'%20stroke-opacity='0.08'/%3E%3C/g%3E%3Cg%20transform='translate(98%20408)%20rotate(18%2042%2042)'%3E